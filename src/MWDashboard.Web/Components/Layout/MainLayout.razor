@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject TenantFilterService TenantFilter
@inject IConfiguration Configuration
@inject AuthenticationStateProvider AuthStateProvider

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Fixed="true" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h5" Class="ml-3">Modern Workplace Dashboard</MudText>
        <MudSpacer />
        @if (TenantFilter.IsHomeTenantUser)
        {
            <TenantSelector />
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Inherit" Class="mr-2">@_scopedTenantName</MudText>
        }
        <AuthorizeView>
            <Authorized>
                <MudTooltip Text="@context.User.Identity?.Name">
                    <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" />
                </MudTooltip>
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" 
                               Href="MicrosoftIdentity/Account/SignOut" />
            </Authorized>
        </AuthorizeView>
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                       Color="Color.Inherit" OnClick="ToggleDarkMode" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Style="margin-top: 48px;" Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;
    private string _scopedTenantName = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userTenantId = authState.User.FindFirst("http://schemas.microsoft.com/identity/claims/tenantid")?.Value;
        var homeTenantId = Configuration["AzureAd:TenantId"];

        if (!string.IsNullOrEmpty(userTenantId) && !userTenantId.Equals(homeTenantId, StringComparison.OrdinalIgnoreCase))
        {
            // Customer-tenant user: restrict to their own tenant only
            TenantFilter.SetTenantScope([userTenantId]);
            await TenantFilter.LoadTenantsAsync();
            _scopedTenantName = TenantFilter.AllTenants.FirstOrDefault()?.DisplayName
                ?? TenantFilter.AllTenants.FirstOrDefault()?.TenantName
                ?? "My Tenant";
        }
        // Home tenant users: no restriction (SetTenantScope not called = null = all data)
    }

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976d2",
            Secondary = "#424242",
            AppbarBackground = "#1976d2"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#90caf9",
            Secondary = "#ce93d8",
            AppbarBackground = "#1e1e2e"
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
}
