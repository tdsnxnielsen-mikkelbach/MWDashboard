@page "/copilot"
@using ApexCharts
@using Color = MudBlazor.Color
@using Size = MudBlazor.Size
@using MWDashboard.Web.Services
@inject IMauDataService MauDataService
@inject TenantFilterService TenantFilter
@inject ICopilotAuditClient CopilotAuditClient
@inject ISnackbar Snackbar
@implements IDisposable

<BrandedPageTitle Page="Copilot Adoption" />

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">Microsoft 365 Copilot Adoption</MudText>
    <div class="d-flex align-center gap-2">
        <MudTooltip Text="Pull the latest unlicensed Copilot Chat audit activity for the selected tenant(s) now. New events can take up to 12 hours to appear after first enabling.">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.CloudSync"
                       Disabled="@_polling"
                       OnClick="PollCopilotChatAsync">
                @(_polling ? "Polling…" : "Poll Copilot Chat")
            </MudButton>
        </MudTooltip>
        <ExportButton Feature="copilot" />
    </div>
</div>


@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    <div class="d-flex flex-column align-center justify-center" style="min-height: 400px;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-4">Loading Copilot data...</MudText>
    </div>
}
else
{
@if (_copilotData.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        No <strong>licensed</strong> Microsoft 365 Copilot usage data is available for the selected tenant(s).
        The Microsoft Graph reports API only returns usage for users who hold a Microsoft 365 Copilot
        license (and requires <PermissionTag Scope="Reports.Read.All" />).
        <br />
        Free <strong>Microsoft 365 Copilot Chat</strong> usage by unlicensed users is <em>not</em> exposed by Graph —
        it is collected separately from the Office 365 Management Activity API and shown in the
        <strong>Copilot Chat (unlicensed)</strong> section below.
    </MudAlert>


    @if (_copilotLicenses.Count > 0)
    {
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Copilot Licenses by Tenant</MudText>
            <MudTable Items="_copilotLicenses" Dense="true" Hover="true" Striped="true">
                <HeaderContent>
                    <MudTh>Tenant</MudTh>
                    <MudTh>SKU</MudTh>
                    <MudTh Style="text-align:right">Assigned</MudTh>
                    <MudTh Style="text-align:right">Total</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Tenant">@context.TenantName</MudTd>
                    <MudTd DataLabel="SKU">@context.SkuPartNumber</MudTd>
                    <MudTd DataLabel="Assigned" Style="text-align:right">@context.Assigned.ToString("N0")</MudTd>
                    <MudTd DataLabel="Total" Style="text-align:right">@context.Total.ToString("N0")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
}
else
{
<MudGrid>
    <!-- KPI Cards -->
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Total Copilot Users</MudText>
            <MudText Typo="Typo.h3" Color="Color.Primary">@_totalActiveUsers.ToString("N0")</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Total Copilot Licenses</MudText>
            <MudText Typo="Typo.h3">@_totalLicenses.ToString("N0")</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Overall Adoption Rate</MudText>
            <MudText Typo="Typo.h3" Color="@(_adoptionRate >= 50 ? Color.Success : Color.Warning)">
                @_adoptionRate.ToString("F1")%
            </MudText>
        </MudPaper>
    </MudItem>

    <!-- Copilot Licenses by Tenant -->
    @if (_copilotLicenses.Count > 0)
    {
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Copilot Licenses by Tenant</MudText>
                <MudTable Items="_copilotLicenses" Dense="true" Hover="true" Striped="true">
                    <HeaderContent>
                        <MudTh>Tenant</MudTh>
                        <MudTh>SKU</MudTh>
                        <MudTh Style="text-align:right">Assigned</MudTh>
                        <MudTh Style="text-align:right">Total</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Tenant">@context.TenantName</MudTd>
                        <MudTd DataLabel="SKU">@context.SkuPartNumber</MudTd>
                        <MudTd DataLabel="Assigned" Style="text-align:right">@context.Assigned.ToString("N0")</MudTd>
                        <MudTd DataLabel="Total" Style="text-align:right">@context.Total.ToString("N0")</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>
    }

    <!-- Per-App Bar Chart -->
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Active Users by Copilot App</MudText>
            <ApexChart TItem="CopilotAppData" Options="_barChartOptions" Height="350">
                @if (TenantFilter.IsMultiTenantView)
                {
                    @foreach (var tenant in _perTenantData.Keys)
                    {
                        <ApexPointSeries TItem="CopilotAppData"
                                         Items="_perTenantData[tenant]"
                                         Name="@tenant"
                                         SeriesType="SeriesType.Bar"
                                         XValue="@(e => e.AppName)"
                                         YValue="@(e => (decimal?)e.ActiveUsers)" />
                    }
                }
                else
                {
                    <ApexPointSeries TItem="CopilotAppData"
                                     Items="_appData"
                                     Name="Active Users"
                                     SeriesType="SeriesType.Bar"
                                     XValue="@(e => e.AppName)"
                                     YValue="@(e => (decimal?)e.ActiveUsers)" />
                }
            </ApexChart>
        </MudPaper>
    </MudItem>

    <!-- Adoption Table -->
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Copilot Adoption Detail</MudText>
            <MudTable Items="_tableData" Dense="true" Hover="true" Striped="true">
                <HeaderContent>
                    @if (TenantFilter.IsMultiTenantView)
                    {
                        <MudTh>Tenant</MudTh>
                    }
                    <MudTh>App</MudTh>
                    <MudTh>Active Users</MudTh>
                    <MudTh>Assigned Licenses</MudTh>
                    <MudTh>Adoption Rate</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @if (TenantFilter.IsMultiTenantView)
                    {
                        <MudTd>@context.TenantName</MudTd>
                    }
                    <MudTd>@context.AppName</MudTd>
                    <MudTd>@context.ActiveUsers.ToString("N0")</MudTd>
                    <MudTd>@context.TotalLicenses.ToString("N0")</MudTd>
                    <MudTd>
                        <MudProgressLinear Color="@GetAdoptionColor(context.AdoptionRate)" Value="@context.AdoptionRate" Class="my-1" Style="min-width: 80px;" />
                        <MudText Typo="Typo.caption">@context.AdoptionRate.ToString("F1")%</MudText>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Color="@GetAdoptionColor(context.AdoptionRate)" Size="Size.Small">
                            @GetAdoptionLabel(context.AdoptionRate)
                        </MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </MudItem>

    <!-- Recommendations -->
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Recommendations</MudText>
            @foreach (var rec in GetRecommendations())
            {
                <MudAlert Severity="@rec.Severity" Dense="true" Class="mb-2">@rec.Message</MudAlert>
            }
        </MudPaper>
    </MudItem>
</MudGrid>
}

<MudDivider Class="my-8" />

<div class="mb-3">
    <MudText Typo="Typo.h5">Copilot Chat (unlicensed)</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Free Microsoft 365 Copilot Chat activity (BizChat, Bing, Edge, Office, M365 App) sourced from the
        Office 365 Management Activity API — usage the Graph reports API does not expose.
    </MudText>
</div>

@if (_chatData.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        No <strong>Copilot Chat</strong> audit activity has been collected for the selected tenant(s) yet. This is expected when:
        <ul class="mt-2 mb-1">
            <li>Collection was only recently enabled — new audit events can take <strong>up to 12 hours</strong> to appear after the subscription is first started.</li>
            <li><strong>Unified audit logging</strong> is turned off for the tenant — it must be enabled, and the app needs <PermissionTag Scope="ActivityFeed.Read" /> (Office 365 Management APIs) consented.</li>
            <li>No one has used the free Copilot Chat experience in the last <strong>7 days</strong> (the audit-blob retention window).</li>
        </ul>
        Use <strong>Poll Copilot Chat</strong> above to pull the latest activity now.
    </MudAlert>
}
else
{
<MudGrid>
    <!-- Copilot Chat KPI Cards -->
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Unlicensed Chat Users</MudText>
            <MudText Typo="Typo.h3" Color="Color.Primary">@_chatUnlicensedLatest.ToString("N0")</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">latest day · by surface</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Active Chat Users</MudText>
            <MudText Typo="Typo.h3">@_chatActiveLatest.ToString("N0")</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">latest day · by surface</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Interactions (30d)</MudText>
            <MudText Typo="Typo.h3">@_chatInteractions30d.ToString("N0")</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Active Surfaces</MudText>
            <MudText Typo="Typo.h3">@_chatSurfaceCount.ToString("N0")</MudText>
        </MudPaper>
    </MudItem>

    <!-- Copilot Chat Trend -->
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Daily Copilot Chat Activity</MudText>
            @if (_chatTrend.Count > 0)
            {
                <ApexChart @key="@_chatTrend.Count" TItem="ChatTrendPoint" Options="_chatTrendOptions" Height="320">
                    <ApexPointSeries TItem="ChatTrendPoint"
                                     Items="_chatTrend"
                                     Name="Interactions"
                                     SeriesType="SeriesType.Area"
                                     XValue="@(e => e.Date.ToString("MMM dd"))"
                                     YValue="@(e => (decimal?)e.Interactions)" />
                    <ApexPointSeries TItem="ChatTrendPoint"
                                     Items="_chatTrend"
                                     Name="Active Users"
                                     SeriesType="SeriesType.Line"
                                     XValue="@(e => e.Date.ToString("MMM dd"))"
                                     YValue="@(e => (decimal?)e.ActiveUsers)" />
                    <ApexPointSeries TItem="ChatTrendPoint"
                                     Items="_chatTrend"
                                     Name="Unlicensed Users"
                                     SeriesType="SeriesType.Line"
                                     XValue="@(e => e.Date.ToString("MMM dd"))"
                                     YValue="@(e => (decimal?)e.UnlicensedUsers)" />
                </ApexChart>
            }
        </MudPaper>
    </MudItem>

    <!-- Copilot Chat per-surface table -->
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Activity by Surface (latest day)</MudText>
            <MudTable Items="_chatBySurface" Dense="true" Hover="true" Striped="true">
                <HeaderContent>
                    @if (TenantFilter.IsMultiTenantView)
                    {
                        <MudTh>Tenant</MudTh>
                    }
                    <MudTh>Surface</MudTh>
                    <MudTh Style="text-align:right">Active Users</MudTh>
                    <MudTh Style="text-align:right">Unlicensed Users</MudTh>
                    <MudTh Style="text-align:right">Interactions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @if (TenantFilter.IsMultiTenantView)
                    {
                        <MudTd DataLabel="Tenant">@context.TenantName</MudTd>
                    }
                    <MudTd DataLabel="Surface">@context.AppHost</MudTd>
                    <MudTd DataLabel="Active Users" Style="text-align:right">@context.ActiveUsers.ToString("N0")</MudTd>
                    <MudTd DataLabel="Unlicensed Users" Style="text-align:right">@context.UnlicensedUsers.ToString("N0")</MudTd>
                    <MudTd DataLabel="Interactions" Style="text-align:right">@context.Interactions.ToString("N0")</MudTd>
                </RowTemplate>
            </MudTable>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                Counts are distinct users per surface per day; a user active on multiple surfaces is counted once per surface.
                Audit events can lag actual usage by up to 12 hours.
            </MudText>
        </MudPaper>
    </MudItem>
</MudGrid>
}
}

@code {
    private List<CopilotUsageSnapshot> _copilotData = [];
    private List<CopilotAppData> _appData = [];
    private List<CopilotTableRow> _tableData = [];
    private List<CopilotLicenseRow> _copilotLicenses = [];
    private Dictionary<string, List<CopilotAppData>> _perTenantData = [];
    private int _totalActiveUsers;
    private int _totalLicenses;
    private double _adoptionRate;
    private bool _loading = true;

    // Copilot Chat (unlicensed) — Office 365 Management Activity API
    private List<CopilotChatUsageSnapshot> _chatData = [];
    private List<ChatTrendPoint> _chatTrend = [];
    private List<ChatSurfaceRow> _chatBySurface = [];
    private int _chatUnlicensedLatest;
    private int _chatActiveLatest;
    private int _chatInteractions30d;
    private int _chatSurfaceCount;
    private bool _polling;

    private readonly ApexChartOptions<ChatTrendPoint> _chatTrendOptions = new()
    {
        Yaxis = [new YAxis { Title = new AxisTitle { Text = "Count" } }],
        Legend = new Legend { Show = true, Position = LegendPosition.Bottom },
        Chart = new Chart { ForeColor = "var(--mud-palette-text-primary)" },
        Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 }
    };

    private ApexChartOptions<CopilotAppData> _barChartOptions = new()
    {
        Yaxis = [new YAxis { Title = new AxisTitle { Text = "Active Users" } }],
        Xaxis = new XAxis { Title = new AxisTitle { Text = "Copilot App" } },
        Legend = new Legend { Show = true, Position = LegendPosition.Bottom },
        Chart = new Chart { ForeColor = "var(--mud-palette-text-primary)" },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = false, ColumnWidth = "60%" } }
    };

    protected override async Task OnInitializedAsync()
    {
        TenantFilter.OnChangeAsync += OnTenantFilterChangedAsync;
        await LoadData();
    }

    private Task OnTenantFilterChangedAsync()
    {
        return InvokeAsync(async () =>
        {
            TenantFilter.SetLoading(true);
            _loading = true;
            StateHasChanged();
            await LoadData();
            TenantFilter.SetLoading(false);
            StateHasChanged();
        });
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();

        var tenantIds = TenantFilter.GetFilteredTenantIds();
        _copilotData = await MauDataService.GetCopilotUsageAsync(tenantIds);

        // Copilot license inventory (shown even when no usage data is returned by Graph,
        // e.g. tenants that only use the free, unlicensed Copilot Chat).
        var licenses = await MauDataService.GetLatestLicensesAsync(tenantIds);
        _copilotLicenses = licenses
            .Where(l => l.SkuPartNumber.Contains("COPILOT", StringComparison.OrdinalIgnoreCase))
            .Select(l => new CopilotLicenseRow
            {
                TenantName = TenantFilter.GetTenantName(l.TenantId),
                SkuPartNumber = l.SkuPartNumber,
                Assigned = l.ConsumedLicenses,
                Total = l.TotalLicenses
            })
            .OrderBy(l => l.TenantName)
            .ThenBy(l => l.SkuPartNumber)
            .ToList();

        // Aggregate per app
        _appData = _copilotData
            .GroupBy(c => c.AppName)
            .Select(g => new CopilotAppData
            {
                AppName = g.Key,
                ActiveUsers = g.Sum(x => x.ActiveUsers)
            })
            .OrderByDescending(a => a.ActiveUsers)
            .ToList();

        // Per-tenant data for multi-tenant view
        if (TenantFilter.IsMultiTenantView)
        {
            _perTenantData = _copilotData
                .GroupBy(c => c.TenantName)
                .ToDictionary(
                    g => g.Key,
                    g => g.Select(c => new CopilotAppData { AppName = c.AppName, ActiveUsers = c.ActiveUsers })
                          .OrderBy(a => a.AppName)
                          .ToList());
        }

        // Table data
        _tableData = _copilotData
            .Select(c => new CopilotTableRow
            {
                TenantName = c.TenantName,
                AppName = c.AppName,
                ActiveUsers = c.ActiveUsers,
                TotalLicenses = c.TotalAssignedLicenses,
                AdoptionRate = c.TotalAssignedLicenses > 0
                    ? (double)c.ActiveUsers / c.TotalAssignedLicenses * 100
                    : 0
            })
            .OrderByDescending(t => t.AdoptionRate)
            .ToList();

        // KPIs - deduplicate by taking max per tenant (users can be active in multiple apps)
        _totalActiveUsers = _copilotData
            .GroupBy(c => c.TenantId)
            .Sum(g => g.Max(c => c.ActiveUsers));
        _totalLicenses = _copilotData
            .GroupBy(c => c.TenantId)
            .Sum(g => g.Max(c => c.TotalAssignedLicenses));
        _adoptionRate = _totalLicenses > 0 ? (double)_totalActiveUsers / _totalLicenses * 100 : 0;

        // Copilot Chat (unlicensed) — separate Office 365 Management Activity API dataset
        _chatData = await MauDataService.GetCopilotChatUsageAsync(tenantIds);
        BuildChatViews();

        _loading = false;
    }

    private void BuildChatViews()
    {
        if (_chatData.Count == 0)
        {
            _chatTrend = [];
            _chatBySurface = [];
            _chatUnlicensedLatest = _chatActiveLatest = _chatInteractions30d = _chatSurfaceCount = 0;
            return;
        }

        // Daily trend — aggregate across tenants/surfaces per report date.
        _chatTrend = _chatData
            .GroupBy(c => c.ReportDate.Date)
            .Select(g => new ChatTrendPoint
            {
                Date = g.Key,
                Interactions = g.Sum(x => x.InteractionCount),
                ActiveUsers = g.Sum(x => x.ActiveUsers),
                UnlicensedUsers = g.Sum(x => x.UnlicensedUsers)
            })
            .OrderBy(p => p.Date)
            .ToList();

        _chatInteractions30d = _chatData.Sum(c => c.InteractionCount);

        // Latest-day breakdown by surface.
        var latestDate = _chatData.Max(c => c.ReportDate.Date);
        var latest = _chatData.Where(c => c.ReportDate.Date == latestDate).ToList();

        // In multi-tenant view, break the surface table down per tenant (mirrors the
        // licensed adoption table); otherwise aggregate across the single tenant in scope.
        if (TenantFilter.IsMultiTenantView)
        {
            _chatBySurface = latest
                .GroupBy(c => new { c.TenantName, c.AppHost })
                .Select(g => new ChatSurfaceRow
                {
                    TenantName = g.Key.TenantName,
                    AppHost = g.Key.AppHost,
                    ActiveUsers = g.Sum(x => x.ActiveUsers),
                    UnlicensedUsers = g.Sum(x => x.UnlicensedUsers),
                    Interactions = g.Sum(x => x.InteractionCount)
                })
                .OrderBy(r => r.TenantName)
                .ThenByDescending(r => r.ActiveUsers)
                .ToList();
        }
        else
        {
            _chatBySurface = latest
                .GroupBy(c => c.AppHost)
                .Select(g => new ChatSurfaceRow
                {
                    AppHost = g.Key,
                    ActiveUsers = g.Sum(x => x.ActiveUsers),
                    UnlicensedUsers = g.Sum(x => x.UnlicensedUsers),
                    Interactions = g.Sum(x => x.InteractionCount)
                })
                .OrderByDescending(r => r.ActiveUsers)
                .ToList();
        }

        _chatUnlicensedLatest = latest.Sum(c => c.UnlicensedUsers);
        _chatActiveLatest = latest.Sum(c => c.ActiveUsers);
        _chatSurfaceCount = latest.Select(c => c.AppHost).Distinct().Count();
    }

    private async Task PollCopilotChatAsync()
    {
        _polling = true;
        StateHasChanged();
        try
        {
            // Poll the tenants currently in scope/selection. SelectedTenantIds is always populated
            // (scoped users see only their own); fall back to all visible tenants if empty.
            var targets = TenantFilter.SelectedTenantIds.Count > 0
                ? TenantFilter.AllTenants.Where(t => TenantFilter.SelectedTenantIds.Contains(t.TenantId)).ToList()
                : TenantFilter.AllTenants.ToList();

            if (targets.Count == 0)
            {
                Snackbar.Add("No tenant selected to poll.", Severity.Warning);
                return;
            }

            var failures = 0;
            var warnings = 0;
            foreach (var tenant in targets)
            {
                try
                {
                    await CopilotAuditClient.CollectForTenantAsync(tenant.TenantId, tenant.TenantName);
                }
                catch (CopilotAuditConfigurationException ex)
                {
                    // Expected tenant-configuration state (audit not provisioned / disabled / not
                    // consented) — an admin action, not a system error. Surface as an informational warning.
                    warnings++;
                    Snackbar.Add($"Copilot Chat not yet available for '{tenant.TenantName}': {ex.Message}", Severity.Warning);
                }
                catch (Exception ex)
                {
                    failures++;
                    Snackbar.Add($"Copilot Chat poll failed for '{tenant.TenantName}': {ex.Message}", Severity.Error);
                }
            }

            await LoadData();
            StateHasChanged();

            if (failures == 0 && warnings == 0)
                Snackbar.Add($"Copilot Chat data refreshed for {targets.Count} tenant(s). New audit events can take up to 12 hours to appear.", Severity.Success);
        }
        finally
        {
            _polling = false;
            StateHasChanged();
        }
    }

    private static Color GetAdoptionColor(double rate) => rate switch
    {
        >= 70 => Color.Success,
        >= 40 => Color.Warning,
        _ => Color.Error
    };

    private static string GetAdoptionLabel(double rate) => rate switch
    {
        >= 70 => "Strong",
        >= 40 => "Growing",
        >= 15 => "Low",
        _ => "Critical"
    };

    private List<Recommendation> GetRecommendations()
    {
        var recs = new List<Recommendation>();

        var lowApps = _tableData.Where(t => t.AdoptionRate < 20).ToList();
        if (lowApps.Count > 0)
        {
            var appNames = string.Join(", ", lowApps.Select(a => a.AppName).Distinct().Take(3));
            recs.Add(new(Severity.Warning,
                $"Low Copilot adoption in {appNames}. Consider targeted enablement workshops or training campaigns."));
        }

        if (_adoptionRate < 30 && _totalLicenses > 0)
        {
            recs.Add(new(Severity.Error,
                $"Overall Copilot adoption is only {_adoptionRate:F0}%. Review license assignment strategy — some users may not be in roles that benefit from Copilot."));
        }

        if (_adoptionRate >= 60)
        {
            recs.Add(new(Severity.Success,
                "Strong Copilot adoption! Consider expanding licenses to additional user groups."));
        }

        if (_copilotData.Any(c => c.AppName == CopilotApps.CopilotChat && c.ActiveUsers > 0) &&
            _copilotData.Where(c => c.AppName != CopilotApps.CopilotChat).All(c => c.ActiveUsers < 5))
        {
            recs.Add(new(Severity.Info,
                "Users are engaging with Copilot Chat but not in-app Copilot features. Promote Copilot in Word, Excel, and Teams for deeper productivity gains."));
        }

        if (recs.Count == 0)
            recs.Add(new(Severity.Info, "Copilot usage is tracking normally. Continue monitoring monthly."));

        return recs;
    }

