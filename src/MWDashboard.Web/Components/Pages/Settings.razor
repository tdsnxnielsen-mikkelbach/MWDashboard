@page "/settings"
@using Color = MudBlazor.Color
@using Size = MudBlazor.Size
@using MudBlazor.Utilities
@inject IDbContextFactory<MauDbContext> DbFactory
@inject TenantFilterService TenantFilter
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<BrandedPageTitle Page="Settings" />

@if (!TenantFilter.IsHomeTenantUser)
{
    NavigationManager.NavigateTo("/", replace: true);
    return;
}

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" data-tour="page-header">Branding & Appearance</MudText>
    <PageTour PageKey="settings" />
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">General</MudText>
            <MudTextField @bind-Value="_settings.AppTitle" Label="Application Title" Placeholder="Modern Workplace Dashboard"
                          Variant="Variant.Outlined" Class="mb-4" />
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Logo & Favicon</MudText>
            
            <MudText Typo="Typo.subtitle2" Class="mb-2">Logo (AppBar)</MudText>
            @if (!string.IsNullOrEmpty(_settings.LogoBase64))
            {
                <div class="mb-2">
                    <img src="data:@(_settings.LogoContentType);base64,@(_settings.LogoBase64)" 
                         style="max-height:40px; max-width:200px;" alt="Current logo" />
                </div>
            }
            <MudFileUpload T="IBrowserFile" Accept=".png,.jpg,.jpeg,.svg,.webp" FilesChanged="OnLogoUpload">
                <CustomContent>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               OnClick="@(() => context.OpenFilePickerAsync())">
                        Upload Logo
                    </MudButton>
                </CustomContent>
            </MudFileUpload>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-1">
                PNG, JPG, SVG or WebP · max 512&nbsp;KB · displayed ~32&nbsp;px tall in the app bar (wide/landscape works best).
            </MudText>
            @if (!string.IsNullOrEmpty(_settings.LogoBase64))
            {
                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="RemoveLogo" Class="mt-1">Remove</MudButton>
            }

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.subtitle2" Class="mb-2">Favicon</MudText>
            @if (!string.IsNullOrEmpty(_settings.FaviconBase64))
            {
                <div class="mb-2">
                    <img src="data:@(_settings.FaviconContentType);base64,@(_settings.FaviconBase64)" 
                         style="max-height:32px; max-width:32px;" alt="Current favicon" />
                </div>
            }
            <MudFileUpload T="IBrowserFile" Accept=".png,.ico,.svg" FilesChanged="OnFaviconUpload">
                <CustomContent>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               OnClick="@(() => context.OpenFilePickerAsync())">
                        Upload Favicon
                    </MudButton>
                </CustomContent>
            </MudFileUpload>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-1">
                PNG, ICO or SVG · max 128&nbsp;KB · square (e.g. 32×32 or 64×64).
                After saving, browsers cache the old icon — do a hard refresh (Ctrl+F5) or reopen the tab to see it.
            </MudText>
            @if (!string.IsNullOrEmpty(_settings.FaviconBase64))
            {
                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="RemoveFavicon" Class="mt-1">Remove</MudButton>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Light Theme</MudText>
            <div class="d-flex align-center mb-3">
                <MudText Class="mr-3" Style="min-width:100px;">Primary</MudText>
                <span class="color-swatch mr-3" style="background:@_lightPrimary.ToString(MudColorOutputFormats.Hex);" title="Current: @_lightPrimary.ToString(MudColorOutputFormats.Hex)"></span>
                <MudColorPicker @bind-Value="_lightPrimary" ShowAlpha="false" ColorPickerMode="ColorPickerMode.HEX" 
                               PickerVariant="PickerVariant.Inline" Style="width:200px;" />
            </div>
            <div class="d-flex align-center mb-3">
                <MudText Class="mr-3" Style="min-width:100px;">Secondary</MudText>
                <span class="color-swatch mr-3" style="background:@_lightSecondary.ToString(MudColorOutputFormats.Hex);" title="Current: @_lightSecondary.ToString(MudColorOutputFormats.Hex)"></span>
                <MudColorPicker @bind-Value="_lightSecondary" ShowAlpha="false" ColorPickerMode="ColorPickerMode.HEX" 
                               PickerVariant="PickerVariant.Inline" Style="width:200px;" />
            </div>
            <div class="d-flex align-center mb-3">
                <MudText Class="mr-3" Style="min-width:100px;">AppBar</MudText>
                <span class="color-swatch mr-3" style="background:@_lightAppbar.ToString(MudColorOutputFormats.Hex);" title="Current: @_lightAppbar.ToString(MudColorOutputFormats.Hex)"></span>
                <MudColorPicker @bind-Value="_lightAppbar" ShowAlpha="false" ColorPickerMode="ColorPickerMode.HEX" 
                               PickerVariant="PickerVariant.Inline" Style="width:200px;" />
            </div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Dark Theme</MudText>
            <div class="d-flex align-center mb-3">
                <MudText Class="mr-3" Style="min-width:100px;">Primary</MudText>
                <span class="color-swatch mr-3" style="background:@_darkPrimary.ToString(MudColorOutputFormats.Hex);" title="Current: @_darkPrimary.ToString(MudColorOutputFormats.Hex)"></span>
                <MudColorPicker @bind-Value="_darkPrimary" ShowAlpha="false" ColorPickerMode="ColorPickerMode.HEX" 
                               PickerVariant="PickerVariant.Inline" Style="width:200px;" />
            </div>
            <div class="d-flex align-center mb-3">
                <MudText Class="mr-3" Style="min-width:100px;">Secondary</MudText>
                <span class="color-swatch mr-3" style="background:@_darkSecondary.ToString(MudColorOutputFormats.Hex);" title="Current: @_darkSecondary.ToString(MudColorOutputFormats.Hex)"></span>
                <MudColorPicker @bind-Value="_darkSecondary" ShowAlpha="false" ColorPickerMode="ColorPickerMode.HEX" 
                               PickerVariant="PickerVariant.Inline" Style="width:200px;" />
            </div>
            <div class="d-flex align-center mb-3">
                <MudText Class="mr-3" Style="min-width:100px;">AppBar</MudText>
                <span class="color-swatch mr-3" style="background:@_darkAppbar.ToString(MudColorOutputFormats.Hex);" title="Current: @_darkAppbar.ToString(MudColorOutputFormats.Hex)"></span>
                <MudColorPicker @bind-Value="_darkAppbar" ShowAlpha="false" ColorPickerMode="ColorPickerMode.HEX" 
                               PickerVariant="PickerVariant.Inline" Style="width:200px;" />
            </div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings" 
                       StartIcon="@Icons.Material.Filled.Save" Disabled="_saving">
                @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Save Changes
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetToDefaults">
                Reset to Defaults
            </MudButton>
        </div>
    </MudItem>
</MudGrid>
}

@code {
    private BrandingSettings _settings = new();
    private bool _loading = true;
    private bool _saving;

    private MudColor _lightPrimary = new("#1976d2");
    private MudColor _lightSecondary = new("#424242");
    private MudColor _lightAppbar = new("#1976d2");
    private MudColor _darkPrimary = new("#90caf9");
    private MudColor _darkSecondary = new("#ce93d8");
    private MudColor _darkAppbar = new("#1e1e2e");

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        _settings = await db.BrandingSettings.FirstOrDefaultAsync() ?? new BrandingSettings();
        _lightPrimary = new MudColor(_settings.LightPrimary);
        _lightSecondary = new MudColor(_settings.LightSecondary);
        _lightAppbar = new MudColor(_settings.LightAppbar);
        _darkPrimary = new MudColor(_settings.DarkPrimary);
        _darkSecondary = new MudColor(_settings.DarkSecondary);
        _darkAppbar = new MudColor(_settings.DarkAppbar);
        _loading = false;
    }

    private async Task SaveSettings()
    {
        _saving = true;
        StateHasChanged();

        _settings.LightPrimary = _lightPrimary.ToString(MudColorOutputFormats.Hex);
        _settings.LightSecondary = _lightSecondary.ToString(MudColorOutputFormats.Hex);
        _settings.LightAppbar = _lightAppbar.ToString(MudColorOutputFormats.Hex);
        _settings.DarkPrimary = _darkPrimary.ToString(MudColorOutputFormats.Hex);
        _settings.DarkSecondary = _darkSecondary.ToString(MudColorOutputFormats.Hex);
        _settings.DarkAppbar = _darkAppbar.ToString(MudColorOutputFormats.Hex);
        _settings.UpdatedAt = DateTime.UtcNow;

        await using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.BrandingSettings.FirstOrDefaultAsync();
        if (existing != null)
        {
            existing.LogoBase64 = _settings.LogoBase64;
            existing.LogoContentType = _settings.LogoContentType;
            existing.FaviconBase64 = _settings.FaviconBase64;
            existing.FaviconContentType = _settings.FaviconContentType;
            existing.LightPrimary = _settings.LightPrimary;
            existing.LightSecondary = _settings.LightSecondary;
            existing.LightAppbar = _settings.LightAppbar;
            existing.DarkPrimary = _settings.DarkPrimary;
            existing.DarkSecondary = _settings.DarkSecondary;
            existing.DarkAppbar = _settings.DarkAppbar;
            existing.AppTitle = _settings.AppTitle;
            existing.UpdatedAt = _settings.UpdatedAt;
        }
        else
        {
            db.BrandingSettings.Add(_settings);
        }
        await db.SaveChangesAsync();

        _saving = false;
        Snackbar.Add("Branding settings saved. Refresh the page to see changes.", Severity.Success);
    }

    private void ResetToDefaults()
    {
        _settings.LightPrimary = "#1976d2";
        _settings.LightSecondary = "#424242";
        _settings.LightAppbar = "#1976d2";
        _settings.DarkPrimary = "#90caf9";
        _settings.DarkSecondary = "#ce93d8";
        _settings.DarkAppbar = "#1e1e2e";
        _settings.AppTitle = null;
        _lightPrimary = new MudColor(_settings.LightPrimary);
        _lightSecondary = new MudColor(_settings.LightSecondary);
        _lightAppbar = new MudColor(_settings.LightAppbar);
        _darkPrimary = new MudColor(_settings.DarkPrimary);
        _darkSecondary = new MudColor(_settings.DarkSecondary);
        _darkAppbar = new MudColor(_settings.DarkAppbar);
    }

    private async Task OnLogoUpload(IBrowserFile file)
    {
        const long maxBytes = 512_000; // 512 KB
        string[] allowed = [".png", ".jpg", ".jpeg", ".svg", ".webp"];
        if (!ValidateUpload(file, allowed, maxBytes, "Logo", "512 KB"))
            return;

        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(maxBytes).CopyToAsync(ms);
            _settings.LogoBase64 = Convert.ToBase64String(ms.ToArray());
            _settings.LogoContentType = ResolveContentType(file);
            Snackbar.Add("Logo selected. Click Save Changes to apply it.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not read the logo file: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnFaviconUpload(IBrowserFile file)
    {
        const long maxBytes = 128_000; // 128 KB
        string[] allowed = [".png", ".ico", ".svg"];
        if (!ValidateUpload(file, allowed, maxBytes, "Favicon", "128 KB"))
            return;

        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(maxBytes).CopyToAsync(ms);
            _settings.FaviconBase64 = Convert.ToBase64String(ms.ToArray());
            _settings.FaviconContentType = ResolveContentType(file);
            Snackbar.Add("Favicon selected. Click Save Changes, then hard-refresh (Ctrl+F5) to see it.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not read the favicon file: {ex.Message}", Severity.Error);
        }
    }

    /// <summary>Validates an uploaded image against allowed extensions and a size cap, reporting failures via snackbar.</summary>
    private bool ValidateUpload(IBrowserFile? file, string[] allowedExtensions, long maxBytes, string label, string maxLabel)
    {
        if (file is null)
        {
            Snackbar.Add($"No {label.ToLowerInvariant()} file was selected.", Severity.Warning);
            return false;
        }

        var ext = Path.GetExtension(file.Name);
        if (string.IsNullOrEmpty(ext) || !allowedExtensions.Contains(ext, StringComparer.OrdinalIgnoreCase))
        {
            Snackbar.Add($"{label} must be one of: {string.Join(", ", allowedExtensions)}. '{file.Name}' is not supported.", Severity.Warning);
            return false;
        }

        if (file.Size == 0)
        {
            Snackbar.Add($"The selected {label.ToLowerInvariant()} file is empty.", Severity.Warning);
            return false;
        }

        if (file.Size > maxBytes)
        {
            Snackbar.Add($"{label} must be under {maxLabel} (selected file is {file.Size / 1024.0:N0} KB).", Severity.Warning);
            return false;
        }

        return true;
    }

    /// <summary>Returns the browser-supplied content type, falling back to a type inferred from the file extension.</summary>
    private static string ResolveContentType(IBrowserFile file)
    {
        if (!string.IsNullOrWhiteSpace(file.ContentType))
            return file.ContentType;

        return Path.GetExtension(file.Name).ToLowerInvariant() switch
        {
            ".png" => "image/png",
            ".jpg" or ".jpeg" => "image/jpeg",
            ".svg" => "image/svg+xml",
            ".webp" => "image/webp",
            ".ico" => "image/x-icon",
            _ => "application/octet-stream",
        };
    }

    private void RemoveLogo()
    {
        _settings.LogoBase64 = null;
        _settings.LogoContentType = null;
    }

    private void RemoveFavicon()
    {
        _settings.FaviconBase64 = null;
        _settings.FaviconContentType = null;
    }
}
