@page "/identity"
@using ApexCharts
@using Color = MudBlazor.Color
@using Size = MudBlazor.Size
@inject IMauDataService MauDataService
@inject TenantFilterService TenantFilter
@implements IDisposable

<BrandedPageTitle Page="Identity & Devices" />

<div class="d-flex justify-space-between align-center mb-2">
    <MudText Typo="Typo.h4">Identity &amp; Devices</MudText>
    <ExportMenu Items="@(new[] {
        ("Device Compliance", "device-compliance"),
        ("Patch / OS Versions", "device-patch"),
        ("Conditional Access", "conditional-access"),
        ("Guest Users", "guests"),
        ("Risky Users", "risky-users"),
        ("App Credential Expiry", "app-credential-expiry"),
        ("OAuth Apps", "oauth-grants"),
        ("Privileged Roles", "privileged-roles") })" />
</div>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Device compliance, Conditional Access coverage, guest/external accounts, identity risk, app credential expiry, and privileged role membership.
    Requires <PermissionTag Scope="DeviceManagementManagedDevices.Read.All" />, <PermissionTag Scope="Policy.Read.All" />,
    <PermissionTag Scope="User.Read.All" />, <PermissionTag Scope="Application.Read.All" />, <PermissionTag Scope="RoleManagement.Read.Directory" />, and (for risk) <PermissionTag Scope="IdentityRiskyUser.Read.All" />.
    <strong>Entra ID license:</strong> Conditional Access requires <strong>P1 or P2</strong>; Risky Users (Identity Protection) requires <strong>P2</strong>; Device Compliance (Intune), Guest Users, App Credentials, and Privileged Roles are available on all tiers.
</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    <div class="d-flex flex-column align-center justify-center" style="min-height: 400px;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-4">Loading identity &amp; device data...</MudText>
    </div>
}
else if (!_hasAnyData)
{
    <MudAlert Severity="Severity.Info">
        No identity or device data available for the selected tenant(s). Collect data from the Tenants page first.
        These insights require the listed Graph permissions to be consented; risky users additionally requires Microsoft Entra ID P2.
    </MudAlert>
}
else
{
<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4">

    @* ---------------- Device Compliance ---------------- *@
    <MudTabPanel Text="Device Compliance" Icon="@Icons.Material.Filled.Devices">
        @if (_devices.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No Intune-managed device data available. Requires <PermissionTag Scope="DeviceManagementManagedDevices.Read.All" />.</MudAlert>
        }
        else
        {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Managed Devices</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_totalDevices.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">enrolled in Intune</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Compliant</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Success">@_compliancePercent.ToString("0.#")%</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_compliantDevices.ToString("N0") devices</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Non-Compliant</MudText>
                    <MudText Typo="Typo.h4" Color="@(_nonCompliantDevices > 0 ? Color.Error : Color.Success)">@_nonCompliantDevices.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">need remediation</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">In Grace / Error</MudText>
                    <MudText Typo="Typo.h4" Color="@(_graceErrorDevices > 0 ? Color.Warning : Color.Success)">@_graceErrorDevices.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">grace period or error</MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Compliance Status</MudText>
                    <ApexChart TItem="LabelValue" Options="_donutOptions" Height="320" @key="_chartKey">
                        <ApexPointSeries TItem="LabelValue" Items="_complianceBreakdown" Name="Devices"
                                         SeriesType="SeriesType.Donut"
                                         XValue="@(e => e.Label)" YValue="@(e => (decimal?)e.Value)" />
                    </ApexChart>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Devices by Platform</MudText>
                    <ApexChart TItem="LabelValue" Options="_barOptions" Height="320" @key="_chartKey">
                        <ApexPointSeries TItem="LabelValue" Items="_platformBreakdown" Name="Devices"
                                         SeriesType="SeriesType.Bar"
                                         XValue="@(e => e.Label)" YValue="@(e => (decimal?)e.Value)" />
                    </ApexChart>
                </MudPaper>
            </MudItem>

            @if (TenantFilter.IsMultiTenantView)
            {
                <MudItem xs="12">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.h6" Class="mb-3">By Tenant</MudText>
                        <MudTable Items="_devices" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                            <HeaderContent>
                                <MudTh>Tenant</MudTh>
                                <MudTh Style="text-align:right">Total</MudTh>
                                <MudTh Style="text-align:right">Compliant</MudTh>
                                <MudTh Style="text-align:right">Non-Compliant</MudTh>
                                <MudTh Style="text-align:right">Grace</MudTh>
                                <MudTh Style="text-align:right">Error</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Tenant">@TenantFilter.GetTenantName(context.TenantId)</MudTd>
                                <MudTd DataLabel="Total" Style="text-align:right">@context.TotalDevices.ToString("N0")</MudTd>
                                <MudTd DataLabel="Compliant" Style="text-align:right">@context.CompliantCount.ToString("N0")</MudTd>
                                <MudTd DataLabel="Non-Compliant" Style="text-align:right">@context.NonCompliantCount.ToString("N0")</MudTd>
                                <MudTd DataLabel="Grace" Style="text-align:right">@context.InGracePeriodCount.ToString("N0")</MudTd>
                                <MudTd DataLabel="Error" Style="text-align:right">@context.ErrorCount.ToString("N0")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
        }
    </MudTabPanel>

    @* ---------------- Patch / OS Versions ---------------- *@
    <MudTabPanel Text="Patch / OS Versions" Icon="@Icons.Material.Filled.SystemUpdate">
        @if (_devicePatch.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No Intune-managed device data available. Requires <PermissionTag Scope="DeviceManagementManagedDevices.Read.All" />.</MudAlert>
        }
        else
        {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Managed Devices</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_patchTotalDevices.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">across @_distinctOsVersions OS build(s)</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Up-to-date Check-in</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Success">@_freshPercent.ToString("0.#")%</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">synced in last 30 days</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Stale Devices</MudText>
                    <MudText Typo="Typo.h4" Color="@(_staleDevices > 0 ? Color.Warning : Color.Success)">@_staleDevices.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">no check-in 30+ days</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Distinct OS Versions</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_distinctOsVersions.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">unique builds in fleet</MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Top OS Versions by Device Count</MudText>
                    <ApexChart TItem="LabelValue" Options="_versionBarOptions" Height="360" @key="_chartKey">
                        <ApexPointSeries TItem="LabelValue" Items="_topOsVersions" Name="Devices"
                                         SeriesType="SeriesType.Bar"
                                         XValue="@(e => e.Label)" YValue="@(e => (decimal?)e.Value)" />
                    </ApexChart>
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-1">Stale-Device Trend (90 days)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
                        Managed devices with no Intune check-in for 30+ days, per collection day. A rising line means patch coverage is
                        slipping (devices dropping off the network or no longer syncing policy).
                    </MudText>
                    @if (_staleTrendSeries.Count > 0)
                    {
                        <ApexChart TItem="TrendPoint" Options="_staleTrendOptions" Height="320" @key="_chartKey">
                            @foreach (var series in _staleTrendSeries)
                            {
                                <ApexPointSeries TItem="TrendPoint" Items="series.Value" Name="@series.Key"
                                                 SeriesType="SeriesType.Line"
                                                 XValue="@(e => e.Date.ToString("MMM dd"))"
                                                 YValue="@(e => (decimal?)e.Stale)" />
                            }
                        </ApexChart>
                    }
                    else
                    {
                        <MudText Color="Color.Secondary">Not enough history yet — the trend appears after a few daily collections.</MudText>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-1">OS-Version Breakdown</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
                        Managed-device distribution by platform and OS build. Stale devices (no Intune check-in for 30+ days) may be
                        missing recent security updates and warrant follow-up.
                    </MudText>
                    <MudTable Items="_devicePatch" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" FixedHeader="true" Height="460px"
                              GroupBy="@(TenantFilter.IsMultiTenantView ? _patchGroupDefinition : null)">
                        <HeaderContent>
                            @if (TenantFilter.IsMultiTenantView) { <MudTh>Tenant</MudTh> }
                            <MudTh>Platform</MudTh>
                            <MudTh>OS Version</MudTh>
                            <MudTh Style="text-align:right">Devices</MudTh>
                            <MudTh Style="text-align:right">Stale (30+ d)</MudTh>
                        </HeaderContent>
                        <GroupHeaderTemplate>
                            <MudTh Class="mud-table-cell-custom-group" colspan="@(TenantFilter.IsMultiTenantView ? 5 : 4)">
                                @TenantFilter.GetTenantName(context.Key?.ToString() ?? string.Empty)
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-inline ml-2">
                                    (@context.Items.Sum(d => d.DeviceCount).ToString("N0") devices, @context.Items.Sum(d => d.StaleCount).ToString("N0") stale)
                                </MudText>
                            </MudTh>
                        </GroupHeaderTemplate>
                        <RowTemplate>
                            @if (TenantFilter.IsMultiTenantView) { <MudTd DataLabel="Tenant">@TenantFilter.GetTenantName(context.TenantId)</MudTd> }
                            <MudTd DataLabel="Platform"><MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@context.OsPlatform</MudChip></MudTd>
                            <MudTd DataLabel="OS Version">@context.OsVersion</MudTd>
                            <MudTd DataLabel="Devices" Style="text-align:right">@context.DeviceCount.ToString("N0")</MudTd>
                            <MudTd DataLabel="Stale (30+ d)" Style="text-align:right">
                                @if (context.StaleCount > 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">@context.StaleCount.ToString("N0")</MudChip>
                                }
                                else
                                {
                                    <span>0</span>
                                }
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new[] { 25, 50, 100 }" />
                        </PagerContent>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
        }
    </MudTabPanel>

    @* ---------------- Conditional Access ---------------- *@
    <MudTabPanel Text="Conditional Access" Icon="@Icons.Material.Filled.Policy">
        @if (_conditionalAccess.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No Conditional Access data available. Requires <PermissionTag Scope="Policy.Read.All" /> and a <strong>Microsoft Entra ID P1 or P2</strong> license (Conditional Access is a premium feature — tenants on the Free tier have no policies to report).</MudAlert>
        }
        else
        {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total Policies</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_totalPolicies.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_enabledPolicies.ToString("N0") enabled</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Report-Only</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Info">@_reportOnlyPolicies.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">not yet enforced</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">MFA Enforced</MudText>
                    <MudText Typo="Typo.h4" Color="@(_mfaCoverage ? Color.Success : Color.Warning)">@(_mfaCoverage ? "Yes" : "Gap")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_mfaTenantCount / @_conditionalAccess.Count tenant(s)</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Legacy Auth Blocked</MudText>
                    <MudText Typo="Typo.h4" Color="@(_legacyBlocked ? Color.Success : Color.Warning)">@(_legacyBlocked ? "Yes" : "Gap")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_legacyTenantCount / @_conditionalAccess.Count tenant(s)</MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Policy States</MudText>
                    <ApexChart TItem="LabelValue" Options="_donutOptions" Height="320" @key="_chartKey">
                        <ApexPointSeries TItem="LabelValue" Items="_policyStateBreakdown" Name="Policies"
                                         SeriesType="SeriesType.Donut"
                                         XValue="@(e => e.Label)" YValue="@(e => (decimal?)e.Value)" />
                    </ApexChart>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-1">Coverage by Tenant</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" /> enforced &nbsp;
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" /> coverage gap (no enabled policy). Conditional Access requires Entra ID P1/P2.
                    </MudText>
                    <MudTable Items="_conditionalAccess" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                        <HeaderContent>
                            <MudTh>Tenant</MudTh>
                            <MudTh Style="text-align:right">Policies</MudTh>
                            <MudTh Style="text-align:right">Enabled</MudTh>
                            <MudTh Style="text-align:center">MFA</MudTh>
                            <MudTh Style="text-align:center">Legacy Blocked</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Tenant">@TenantFilter.GetTenantName(context.TenantId)</MudTd>
                            <MudTd DataLabel="Policies" Style="text-align:right">@context.TotalPolicies.ToString("N0")</MudTd>
                            <MudTd DataLabel="Enabled" Style="text-align:right">@context.EnabledPolicies.ToString("N0")</MudTd>
                            <MudTd DataLabel="MFA" Style="text-align:center">
                                <MudTooltip Text="@(context.RequiresMfa ? "An enabled Conditional Access policy enforces MFA" : "Coverage gap: no enabled policy enforces MFA")">
                                    <MudIcon Icon="@(context.RequiresMfa ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Warning)"
                                             Color="@(context.RequiresMfa ? Color.Success : Color.Warning)" Size="Size.Small" />
                                </MudTooltip>
                            </MudTd>
                            <MudTd DataLabel="Legacy Blocked" Style="text-align:center">
                                <MudTooltip Text="@(context.BlocksLegacyAuth ? "An enabled Conditional Access policy blocks legacy authentication" : "Coverage gap: no enabled policy blocks legacy authentication")">
                                    <MudIcon Icon="@(context.BlocksLegacyAuth ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Warning)"
                                             Color="@(context.BlocksLegacyAuth ? Color.Success : Color.Warning)" Size="Size.Small" />
                                </MudTooltip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
        }
    </MudTabPanel>

    @* ---------------- Guest Users ---------------- *@
    <MudTabPanel Text="Guest Users" Icon="@Icons.Material.Filled.GroupAdd">
        @if (_guests.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No guest/external user data available. Requires <PermissionTag Scope="User.Read.All" />.</MudAlert>
        }
        else
        {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total Guests</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_totalGuests.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">external accounts</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Accepted</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Success">@_acceptedGuests.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">invitation accepted</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Pending</MudText>
                    <MudText Typo="Typo.h4" Color="@(_pendingGuests > 0 ? Color.Warning : Color.Success)">@_pendingGuests.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">awaiting acceptance</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Added (30 days)</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Info">@_recentGuests.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">recently invited</MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Invitation Status</MudText>
                    <ApexChart TItem="LabelValue" Options="_donutOptions" Height="320" @key="_chartKey">
                        <ApexPointSeries TItem="LabelValue" Items="_guestBreakdown" Name="Guests"
                                         SeriesType="SeriesType.Donut"
                                         XValue="@(e => e.Label)" YValue="@(e => (decimal?)e.Value)" />
                    </ApexChart>
                </MudPaper>
            </MudItem>
            @if (TenantFilter.IsMultiTenantView)
            {
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.h6" Class="mb-3">By Tenant</MudText>
                        <MudTable Items="_guests" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                            <HeaderContent>
                                <MudTh>Tenant</MudTh>
                                <MudTh Style="text-align:right">Total</MudTh>
                                <MudTh Style="text-align:right">Accepted</MudTh>
                                <MudTh Style="text-align:right">Pending</MudTh>
                                <MudTh Style="text-align:right">New (30d)</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Tenant">@TenantFilter.GetTenantName(context.TenantId)</MudTd>
                                <MudTd DataLabel="Total" Style="text-align:right">@context.TotalGuests.ToString("N0")</MudTd>
                                <MudTd DataLabel="Accepted" Style="text-align:right">@context.AcceptedGuests.ToString("N0")</MudTd>
                                <MudTd DataLabel="Pending" Style="text-align:right">@context.PendingAcceptanceGuests.ToString("N0")</MudTd>
                                <MudTd DataLabel="New (30d)" Style="text-align:right">@context.RecentlyAddedGuests.ToString("N0")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
        }
    </MudTabPanel>

    @* ---------------- Risky Users ---------------- *@
    <MudTabPanel Text="Risky Users" Icon="@Icons.Material.Filled.GppMaybe">
        @if (_riskyUsers.Count == 0)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-2">
                No identity risk data available. Risky-user analysis uses Microsoft Entra ID <strong>Identity Protection</strong>,
                which requires the <PermissionTag Scope="IdentityRiskyUser.Read.All" /> permission <strong>and an Entra ID P2 license</strong>
                on the target tenant. Tenants below P2 are skipped during collection (this is a licensing limit, not a consent gap).
            </MudAlert>
            @if (_nonP2Tenants.Count > 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    Selected tenant(s) without Entra ID P2: <strong>@string.Join(", ", _nonP2Tenants)</strong>.
                </MudAlert>
            }
        }
        else
        {
        @if (_nonP2Tenants.Count > 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                Risky-user data requires Entra ID P2. The following selected tenant(s) lack P2 and are excluded from these figures:
                <strong>@string.Join(", ", _nonP2Tenants)</strong>.
            </MudAlert>
        }
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">At Risk</MudText>
                    <MudText Typo="Typo.h4" Color="@(_totalAtRisk > 0 ? Color.Error : Color.Success)">@_totalAtRisk.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">users flagged</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">High Risk</MudText>
                    <MudText Typo="Typo.h4" Color="@(_highRisk > 0 ? Color.Error : Color.Success)">@_highRisk.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">immediate attention</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Medium Risk</MudText>
                    <MudText Typo="Typo.h4" Color="@(_mediumRisk > 0 ? Color.Warning : Color.Success)">@_mediumRisk.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">review recommended</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Low Risk</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Info">@_lowRisk.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">monitor</MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Risk Levels</MudText>
                    <ApexChart TItem="LabelValue" Options="_donutOptions" Height="320" @key="_chartKey">
                        <ApexPointSeries TItem="LabelValue" Items="_riskBreakdown" Name="Users"
                                         SeriesType="SeriesType.Donut"
                                         XValue="@(e => e.Label)" YValue="@(e => (decimal?)e.Value)" />
                    </ApexChart>
                </MudPaper>
            </MudItem>
            @if (TenantFilter.IsMultiTenantView)
            {
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.h6" Class="mb-3">By Tenant</MudText>
                        <MudTable Items="_riskyUsers" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                            <HeaderContent>
                                <MudTh>Tenant</MudTh>
                                <MudTh Style="text-align:right">At Risk</MudTh>
                                <MudTh Style="text-align:right">High</MudTh>
                                <MudTh Style="text-align:right">Medium</MudTh>
                                <MudTh Style="text-align:right">Low</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Tenant">@TenantFilter.GetTenantName(context.TenantId)</MudTd>
                                <MudTd DataLabel="At Risk" Style="text-align:right">@context.TotalAtRisk.ToString("N0")</MudTd>
                                <MudTd DataLabel="High" Style="text-align:right">@context.HighRisk.ToString("N0")</MudTd>
                                <MudTd DataLabel="Medium" Style="text-align:right">@context.MediumRisk.ToString("N0")</MudTd>
                                <MudTd DataLabel="Low" Style="text-align:right">@context.LowRisk.ToString("N0")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
        }
    </MudTabPanel>

    @* ---------------- App Credential Expiry ---------------- *@
    <MudTabPanel Text="App Credential Expiry" Icon="@Icons.Material.Filled.VpnKey">
        @if (_appCredentials.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No app credential data available. Requires <PermissionTag Scope="Application.Read.All" />.</MudAlert>
        }
        else
        {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Credentials</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_appCredentials.Count.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">secrets &amp; certificates</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Expired</MudText>
                    <MudText Typo="Typo.h4" Color="@(_expiredCreds > 0 ? Color.Error : Color.Success)">@_expiredCreds.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">already lapsed</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Expiring ≤ 30 days</MudText>
                    <MudText Typo="Typo.h4" Color="@(_expiring30 > 0 ? Color.Warning : Color.Success)">@_expiring30.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">rotate soon</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Expiring ≤ 90 days</MudText>
                    <MudText Typo="Typo.h4" Color="@(_expiring90 > 0 ? Color.Warning : Color.Success)">@_expiring90.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">plan rotation</MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Credentials by Expiry</MudText>
                    <MudTable Items="_appCredentials" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm"
                              SortLabel="Sort" Filter="null">
                        <HeaderContent>
                            @if (TenantFilter.IsMultiTenantView) { <MudTh>Tenant</MudTh> }
                            <MudTh>Application</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh Style="text-align:right">Expires</MudTh>
                            <MudTh Style="text-align:right">Days</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            @if (TenantFilter.IsMultiTenantView) { <MudTd DataLabel="Tenant">@TenantFilter.GetTenantName(context.TenantId)</MudTd> }
                            <MudTd DataLabel="Application">@context.AppDisplayName</MudTd>
                            <MudTd DataLabel="Type">@context.CredentialType</MudTd>
                            <MudTd DataLabel="Name">@(string.IsNullOrEmpty(context.DisplayName) ? "—" : context.DisplayName)</MudTd>
                            <MudTd DataLabel="Expires" Style="text-align:right">@context.EndDateTime.ToString("yyyy-MM-dd")</MudTd>
                            <MudTd DataLabel="Days" Style="text-align:right">@context.DaysToExpiry.ToString("N0")</MudTd>
                            <MudTd DataLabel="Status">
                                @if (context.IsExpired)
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Filled">Expired</MudChip>
                                }
                                else if (context.DaysToExpiry <= 30)
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled">Expiring soon</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Outlined">Valid</MudChip>
                                }
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new[] { 25, 50, 100 }" />
                        </PagerContent>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
        }
    </MudTabPanel>

    @* ---------------- Privileged Roles ---------------- *@
    <MudTabPanel Text="Privileged Roles" Icon="@Icons.Material.Filled.AdminPanelSettings">
        @if (_privilegedRoles.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No privileged role data available. Requires <PermissionTag Scope="RoleManagement.Read.Directory" />.</MudAlert>
        }
        else
        {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Active Roles</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_privilegedRoles.Count.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">with members</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Global Admins</MudText>
                    <MudText Typo="Typo.h4" Color="@(_globalAdmins > 5 ? Color.Warning : Color.Primary)">@_globalAdmins.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">standing assignments</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Privileged Members</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_privilegedMembers.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">across high-impact roles</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">High-Impact Roles</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_privilegedRoles.Count(r => r.IsPrivileged).ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">flagged sensitive</MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Role Membership</MudText>
                    <MudTable Items="_privilegedRoles" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm"
                              GroupBy="@(TenantFilter.IsMultiTenantView ? _roleGroupDefinition : null)">
                        <HeaderContent>
                            <MudTh>Role</MudTh>
                            <MudTh Style="text-align:right">Members</MudTh>
                            <MudTh>Sensitivity</MudTh>
                        </HeaderContent>
                        <GroupHeaderTemplate>
                            <MudTh Class="mud-table-cell-custom-group" colspan="3">
                                <MudText Typo="Typo.subtitle2">@TenantFilter.GetTenantName(context.Key?.ToString() ?? string.Empty)</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">
                                    @context.Items.Count() role(s), @context.Items.Sum(r => r.MemberCount).ToString("N0") member(s)
                                </MudText>
                            </MudTh>
                        </GroupHeaderTemplate>
                        <RowTemplate>
                            <MudTd DataLabel="Role">@context.RoleName</MudTd>
                            <MudTd DataLabel="Members" Style="text-align:right">@context.MemberCount.ToString("N0")</MudTd>
                            <MudTd DataLabel="Sensitivity">
                                @if (context.IsPrivileged)
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled">High-impact</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">Standard</MudChip>
                                }
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new[] { 25, 50, 100 }" />
                        </PagerContent>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
        }
    </MudTabPanel>

    <MudTabPanel Text="OAuth Apps" Icon="@Icons.Material.Filled.Apps">
        @if (_oauthGrants.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No OAuth app consent grants found for the selected tenant(s). Requires <PermissionTag Scope="Application.Read.All" /> + <PermissionTag Scope="Directory.Read.All" />.</MudAlert>
        }
        else
        {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Consented Apps</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_oauthGrants.Count.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">with delegated grants</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">High-Risk Apps</MudText>
                    <MudText Typo="Typo.h4" Color="@(_oauthHighRisk > 0 ? Color.Warning : Color.Success)">@_oauthHighRisk.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">hold sensitive scopes</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Admin-Consented</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_oauthAdminConsented.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">tenant-wide grants</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total Scopes</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_oauthGrants.Sum(g => g.ScopeCount).ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">delegated permissions</MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-1">Third-Party App Consent</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
                        Delegated OAuth grants consented to apps in the tenant. Apps holding high-risk scopes (mailbox, files, directory, app management)
                        warrant review — over-privileged or unrecognized apps are a common data-exfiltration vector.
                    </MudText>
                    <MudTable Items="_oauthGrants" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" FixedHeader="true" Height="460px">
                        <HeaderContent>
                            @if (TenantFilter.IsMultiTenantView) { <MudTh>Tenant</MudTh> }
                            <MudTh>Application</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh Style="text-align:right">Scopes</MudTh>
                            <MudTh>High-Risk Scopes</MudTh>
                            <MudTh>Consent</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            @if (TenantFilter.IsMultiTenantView) { <MudTd DataLabel="Tenant">@TenantFilter.GetTenantName(context.TenantId)</MudTd> }
                            <MudTd DataLabel="Application">@context.AppDisplayName</MudTd>
                            <MudTd DataLabel="Type"><MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@context.GrantType</MudChip></MudTd>
                            <MudTd DataLabel="Scopes" Style="text-align:right">@context.ScopeCount.ToString("N0")</MudTd>
                            <MudTd DataLabel="High-Risk Scopes">
                                @if (string.IsNullOrEmpty(context.HighRiskScopes))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">None</MudChip>
                                }
                                else
                                {
                                    @foreach (var scope in context.HighRiskScopes.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Class="ma-1">@scope</MudChip>
                                    }
                                }
                            </MudTd>
                            <MudTd DataLabel="Consent">
                                @if (context.IsAdminConsented)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">Admin (all users)</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">User</MudChip>
                                }
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new[] { 25, 50, 100 }" />
                        </PagerContent>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
        }
    </MudTabPanel>

</MudTabs>
}

@code {
    private bool _loading = true;
    private bool _hasAnyData;
    private int _chartKey;

    private List<DeviceComplianceSnapshot> _devices = [];
    private List<DevicePatchSnapshot> _devicePatch = [];
    private List<DevicePatchSnapshot> _devicePatchHistory = [];
    private List<ConditionalAccessSnapshot> _conditionalAccess = [];
    private List<GuestUserSnapshot> _guests = [];
    private List<RiskyUserSnapshot> _riskyUsers = [];
    private List<AppCredentialSnapshot> _appCredentials = [];
    private List<PrivilegedRoleSnapshot> _privilegedRoles = [];
    private List<OAuthGrantSnapshot> _oauthGrants = [];
    private int _oauthHighRisk, _oauthAdminConsented;

    // Groups the Role Membership table by tenant (collapsible) in multi-tenant view.
    private readonly TableGroupDefinition<PrivilegedRoleSnapshot> _roleGroupDefinition = new()
    {
        GroupName = "Tenant",
        Indentation = false,
        Expandable = true,
        Selector = s => s.TenantId
    };

    // Groups the OS-version table by tenant (collapsible) in multi-tenant view.
    private readonly TableGroupDefinition<DevicePatchSnapshot> _patchGroupDefinition = new()
    {
        GroupName = "Tenant",
        Indentation = false,
        Expandable = true,
        Selector = s => s.TenantId
    };

    // Device KPIs
    private int _totalDevices, _compliantDevices, _nonCompliantDevices, _graceErrorDevices;
    private double _compliancePercent;
    private List<LabelValue> _complianceBreakdown = [];
    private List<LabelValue> _platformBreakdown = [];

    // Device patch / OS-version KPIs
    private int _patchTotalDevices, _staleDevices, _distinctOsVersions;
    private double _freshPercent;
    private List<LabelValue> _topOsVersions = [];
    private Dictionary<string, List<TrendPoint>> _staleTrendSeries = [];

    // Conditional Access KPIs
    private int _totalPolicies, _enabledPolicies, _reportOnlyPolicies;
    private bool _mfaCoverage, _legacyBlocked;
    private int _mfaTenantCount, _legacyTenantCount;
    private List<LabelValue> _policyStateBreakdown = [];

    // Guest KPIs
    private int _totalGuests, _acceptedGuests, _pendingGuests, _recentGuests;
    private List<LabelValue> _guestBreakdown = [];

    // Risky user KPIs
    private int _totalAtRisk, _highRisk, _mediumRisk, _lowRisk;
    private List<LabelValue> _riskBreakdown = [];
    private List<string> _nonP2Tenants = [];

    // App credential KPIs
    private int _expiredCreds, _expiring30, _expiring90;

    // Privileged role KPIs
    private int _globalAdmins, _privilegedMembers;

    private readonly ApexChartOptions<LabelValue> _donutOptions = new()
    {
        Legend = new Legend { Show = true, Position = LegendPosition.Bottom },
        Chart = new Chart { ForeColor = "var(--mud-palette-text-primary)" }
    };

    private readonly ApexChartOptions<LabelValue> _barOptions = new()
    {
        Legend = new Legend { Show = false },
        Chart = new Chart { ForeColor = "var(--mud-palette-text-primary)" },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = false, Distributed = true } },
        DataLabels = new DataLabels { Enabled = true }
    };

    private readonly ApexChartOptions<LabelValue> _versionBarOptions = new()
    {
        Legend = new Legend { Show = false },
        Chart = new Chart { ForeColor = "var(--mud-palette-text-primary)" },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = true, Distributed = true } },
        DataLabels = new DataLabels { Enabled = true }
    };

    private readonly ApexChartOptions<TrendPoint> _staleTrendOptions = new()
    {
        Legend = new Legend { Show = true, Position = LegendPosition.Bottom },
        Chart = new Chart { ForeColor = "var(--mud-palette-text-primary)" },
        Yaxis = [new YAxis { Min = 0, Title = new AxisTitle { Text = "Stale devices" } }],
        Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 }
    };

    protected override async Task OnInitializedAsync()
    {
        TenantFilter.OnChangeAsync += OnTenantFilterChangedAsync;
        await LoadData();
    }

    private Task OnTenantFilterChangedAsync()
    {
        return InvokeAsync(async () =>
        {
            TenantFilter.SetLoading(true);
            _loading = true;
            StateHasChanged();
            await LoadData();
            TenantFilter.SetLoading(false);
            StateHasChanged();
        });
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();

        var tenantIds = TenantFilter.GetFilteredTenantIds();

        _devices = await MauDataService.GetDeviceComplianceAsync(tenantIds);
        _devicePatch = (await MauDataService.GetDevicePatchAsync(tenantIds))
            .OrderByDescending(p => p.DeviceCount).ToList();
        _devicePatchHistory = await MauDataService.GetDevicePatchHistoryAsync(tenantIds, days: 90);
        _conditionalAccess = await MauDataService.GetConditionalAccessAsync(tenantIds);
        _guests = await MauDataService.GetGuestUsersAsync(tenantIds);
        _riskyUsers = await MauDataService.GetRiskyUsersAsync(tenantIds);
        _appCredentials = (await MauDataService.GetAppCredentialsAsync(tenantIds))
            .OrderBy(c => c.DaysToExpiry).ToList();
        _privilegedRoles = (await MauDataService.GetPrivilegedRolesAsync(tenantIds))
            .OrderByDescending(r => r.IsPrivileged).ThenByDescending(r => r.MemberCount).ToList();
        _oauthGrants = (await MauDataService.GetOAuthGrantsAsync(tenantIds))
            .OrderByDescending(g => !string.IsNullOrEmpty(g.HighRiskScopes)).ThenByDescending(g => g.ScopeCount).ToList();

        // Tier info so the Risky Users tab can explain why P2-only data is missing
        var tiers = await MauDataService.GetTenantEntraIdTiersAsync();
        var scoped = tenantIds?.ToHashSet();
        _nonP2Tenants = tiers
            .Where(t => t.Tier != "P2" && (scoped == null || scoped.Contains(t.TenantId)))
            .Select(t => TenantFilter.GetTenantName(t.TenantId))
            .OrderBy(n => n)
            .ToList();

        _hasAnyData = _devices.Count > 0 || _conditionalAccess.Count > 0 || _guests.Count > 0 || _riskyUsers.Count > 0
            || _appCredentials.Count > 0 || _privilegedRoles.Count > 0 || _oauthGrants.Count > 0 || _devicePatch.Count > 0;

        BuildDeviceMetrics();
        BuildDevicePatchMetrics();
        BuildConditionalAccessMetrics();
        BuildGuestMetrics();
        BuildRiskyUserMetrics();
        BuildGovernanceMetrics();

        _chartKey++;
        _loading = false;
    }

    private void BuildGovernanceMetrics()
    {
        _expiredCreds = _appCredentials.Count(c => c.IsExpired);
        _expiring30 = _appCredentials.Count(c => !c.IsExpired && c.DaysToExpiry <= 30);
        _expiring90 = _appCredentials.Count(c => !c.IsExpired && c.DaysToExpiry <= 90);

        _globalAdmins = _privilegedRoles
            .Where(r => r.RoleName == "Global Administrator")
            .Sum(r => r.MemberCount);
        _privilegedMembers = _privilegedRoles
            .Where(r => r.IsPrivileged)
            .Sum(r => r.MemberCount);

        _oauthHighRisk = _oauthGrants.Count(g => !string.IsNullOrEmpty(g.HighRiskScopes));
        _oauthAdminConsented = _oauthGrants.Count(g => g.IsAdminConsented);
    }

    private void BuildDeviceMetrics()
    {
        _totalDevices = _devices.Sum(d => d.TotalDevices);
        _compliantDevices = _devices.Sum(d => d.CompliantCount);
        _nonCompliantDevices = _devices.Sum(d => d.NonCompliantCount);
        _graceErrorDevices = _devices.Sum(d => d.InGracePeriodCount + d.ErrorCount);
        _compliancePercent = _totalDevices > 0 ? (double)_compliantDevices / _totalDevices * 100 : 0;

        _complianceBreakdown =
        [
            new("Compliant", _compliantDevices),
            new("Non-Compliant", _nonCompliantDevices),
            new("In Grace Period", _devices.Sum(d => d.InGracePeriodCount)),
            new("Error", _devices.Sum(d => d.ErrorCount)),
            new("Unknown", _devices.Sum(d => d.UnknownCount))
        ];
        _complianceBreakdown = _complianceBreakdown.Where(x => x.Value > 0).ToList();

        _platformBreakdown =
        [
            new("Windows", _devices.Sum(d => d.WindowsCount)),
            new("iOS / iPadOS", _devices.Sum(d => d.IosCount)),
            new("Android", _devices.Sum(d => d.AndroidCount)),
            new("macOS", _devices.Sum(d => d.MacOsCount)),
            new("Other", _devices.Sum(d => d.OtherOsCount))
        ];
        _platformBreakdown = _platformBreakdown.Where(x => x.Value > 0).ToList();
    }

    private void BuildDevicePatchMetrics()
    {
        _patchTotalDevices = _devicePatch.Sum(p => p.DeviceCount);
        _staleDevices = _devicePatch.Sum(p => p.StaleCount);
        _distinctOsVersions = _devicePatch
            .Select(p => (p.OsPlatform, p.OsVersion))
            .Distinct()
            .Count();
        _freshPercent = _patchTotalDevices > 0
            ? (double)(_patchTotalDevices - _staleDevices) / _patchTotalDevices * 100
            : 0;

        // Top OS versions across the fleet (aggregate across tenants by platform + version).
        _topOsVersions = _devicePatch
            .GroupBy(p => $"{p.OsPlatform} {p.OsVersion}")
            .Select(g => new LabelValue(g.Key, g.Sum(p => p.DeviceCount)))
            .OrderByDescending(x => x.Value)
            .Take(12)
            .ToList();

        // Stale-device trend over the retained history — per-tenant series in multi-tenant view.
        _staleTrendSeries = [];
        if (TenantFilter.IsMultiTenantView)
        {
            foreach (var group in _devicePatchHistory.GroupBy(s => s.TenantId))
            {
                var points = group
                    .GroupBy(s => s.ReportDate)
                    .OrderBy(g => g.Key)
                    .Select(g => new TrendPoint(g.Key, g.Sum(s => s.StaleCount)))
                    .ToList();
                if (points.Count > 0)
                    _staleTrendSeries[TenantFilter.GetTenantName(group.Key)] = points;
            }
        }
        else
        {
            var points = _devicePatchHistory
                .GroupBy(s => s.ReportDate)
                .OrderBy(g => g.Key)
                .Select(g => new TrendPoint(g.Key, g.Sum(s => s.StaleCount)))
                .ToList();
            if (points.Count > 0)
                _staleTrendSeries["Stale devices"] = points;
        }
    }

    private void BuildConditionalAccessMetrics()
    {
        _totalPolicies = _conditionalAccess.Sum(c => c.TotalPolicies);
        _enabledPolicies = _conditionalAccess.Sum(c => c.EnabledPolicies);
        _reportOnlyPolicies = _conditionalAccess.Sum(c => c.ReportOnlyPolicies);

        _mfaTenantCount = _conditionalAccess.Count(c => c.RequiresMfa);
        _legacyTenantCount = _conditionalAccess.Count(c => c.BlocksLegacyAuth);
        _mfaCoverage = _conditionalAccess.Count > 0 && _mfaTenantCount == _conditionalAccess.Count;
        _legacyBlocked = _conditionalAccess.Count > 0 && _legacyTenantCount == _conditionalAccess.Count;

        _policyStateBreakdown =
        [
            new("Enabled", _enabledPolicies),
            new("Report-Only", _reportOnlyPolicies),
            new("Disabled", _conditionalAccess.Sum(c => c.DisabledPolicies))
        ];
        _policyStateBreakdown = _policyStateBreakdown.Where(x => x.Value > 0).ToList();
    }

    private void BuildGuestMetrics()
    {
        _totalGuests = _guests.Sum(g => g.TotalGuests);
        _acceptedGuests = _guests.Sum(g => g.AcceptedGuests);
        _pendingGuests = _guests.Sum(g => g.PendingAcceptanceGuests);
        _recentGuests = _guests.Sum(g => g.RecentlyAddedGuests);

        var other = _totalGuests - _acceptedGuests - _pendingGuests;
        _guestBreakdown =
        [
            new("Accepted", _acceptedGuests),
            new("Pending", _pendingGuests),
            new("Other", other > 0 ? other : 0)
        ];
        _guestBreakdown = _guestBreakdown.Where(x => x.Value > 0).ToList();
    }

    private void BuildRiskyUserMetrics()
    {
        _totalAtRisk = _riskyUsers.Sum(r => r.TotalAtRisk);
        _highRisk = _riskyUsers.Sum(r => r.HighRisk);
        _mediumRisk = _riskyUsers.Sum(r => r.MediumRisk);
        _lowRisk = _riskyUsers.Sum(r => r.LowRisk);

        _riskBreakdown =
        [
            new("High", _highRisk),
            new("Medium", _mediumRisk),
            new("Low", _lowRisk)
        ];
        _riskBreakdown = _riskBreakdown.Where(x => x.Value > 0).ToList();
    }

    public void Dispose()
    {
        TenantFilter.OnChangeAsync -= OnTenantFilterChangedAsync;
    }

    private record LabelValue(string Label, int Value);
    private record TrendPoint(DateTime Date, int Stale);
}
