@page "/tenants"
@inject IDbContextFactory<MauDbContext> DbFactory
@inject IConfiguration Configuration
@inject IJSRuntime JS
@inject IDataCollectionService DataCollectionService
@inject IGraphReportService GraphService
@inject IMauDataService DataService
@inject TenantFilterService TenantFilter
@inject NavigationManager NavigationManager

<PageTitle>Tenant Management</PageTitle>

@if (!TenantFilter.IsHomeTenantUser)
{
    NavigationManager.NavigateTo("/", replace: true);
    return;
}

<MudText Typo="Typo.h4" Class="mb-4">Tenant Management</MudText>

@{
    var tenantsNeedingConsent = _tenants.Where(t => !string.IsNullOrWhiteSpace(t.MissingPermissions)).ToList();
}
@if (tenantsNeedingConsent.Count > 0)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4" Icon="@Icons.Material.Filled.GppMaybe">
        <MudText Typo="Typo.subtitle2">Re-consent required</MudText>
        <MudText Typo="Typo.body2" Class="mb-2">
            @tenantsNeedingConsent.Count tenant@(tenantsNeedingConsent.Count == 1 ? "" : "s") @(tenantsNeedingConsent.Count == 1 ? "is" : "are")
            missing consent for one or more Graph permissions. Some data will not be collected until the customer's Global Admin re-runs admin consent.
        </MudText>
        <MudList T="string" Dense="true" DisablePadding="true">
            @foreach (var t in tenantsNeedingConsent)
            {
                <MudListItem T="string" Icon="@Icons.Material.Filled.Warning" IconColor="Color.Warning">
                    <strong>@t.DisplayName</strong> — missing: @FormatMissingPermissions(t.MissingPermissions)
                    <MudLink Href="@GetConsentUrlForTenant(t.TenantId)" Target="_blank" Class="ml-2">Open consent link</MudLink>
                </MudListItem>
            }
        </MudList>
    </MudAlert>
}

<MudGrid>
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Register New Tenant</MudText>
            <MudForm @ref="_form">
                <MudTextField @bind-Value="_newTenant.TenantId" Label="Tenant ID (GUID)" Required="true" Class="mb-3" />
                <MudTextField @bind-Value="_newTenant.TenantName" Label="Tenant Name" Required="true" Class="mb-3" />
                <MudTextField @bind-Value="_newTenant.DisplayName" Label="Display Name" Class="mb-3" />
            </MudForm>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddTenant" Disabled="@(!IsValid)">
                Add Tenant
            </MudButton>
            @if (!string.IsNullOrEmpty(_message))
            {
                <MudAlert Severity="@_severity" Class="mt-3">@_message</MudAlert>
            }
        </MudPaper>

        <MudPaper Class="pa-4 mt-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Admin Consent Link Generator</MudText>
            <MudText Typo="Typo.body2" Class="mb-3">
                Generate a consent URL for a tenant admin to authorize this application.
                Send this link to the customer's Global Admin.
            </MudText>
            <MudTextField @bind-Value="_consentTenantId" Label="Target Tenant ID (GUID)" Class="mb-3" />
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="GenerateConsentUrl" 
                       Disabled="@string.IsNullOrWhiteSpace(_consentTenantId)">
                Generate URL
            </MudButton>
            @if (!string.IsNullOrEmpty(_consentUrl))
            {
                <MudAlert Severity="Severity.Info" Class="mt-3">
                    <MudText Typo="Typo.body2" Class="mb-1">Send this URL to the tenant admin:</MudText>
                    <MudLink Href="@_consentUrl" Target="_blank" Typo="Typo.caption" Style="word-break: break-all;">
                        @_consentUrl
                    </MudLink>
                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" 
                               OnClick="CopyConsentUrl" Class="mt-2">
                        Copy to clipboard
                    </MudButton>
                </MudAlert>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Registered Tenants</MudText>
            <MudTable Items="_tenants" Dense="true" Hover="true" Loading="_loading">
                <HeaderContent>
                    <MudTh>Tenant Name</MudTh>
                    <MudTh>Tenant ID</MudTh>
                    <MudTh>Plan</MudTh>
                    <MudTh>Active</MudTh>
                    <MudTh>Consent</MudTh>
                    <MudTh>Onboarded</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        @if (_editingTenantId == context.TenantId)
                        {
                            <MudTextField @bind-Value="_editDisplayName" Variant="Variant.Outlined" Margin="Margin.Dense" 
                                          Immediate="true" Style="max-width: 200px; display: inline-block;" />
                            <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" 
                                           OnClick="@(() => SaveDisplayName(context))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" Size="Size.Small" 
                                           OnClick="CancelEdit" />
                        }
                        else
                        {
                            @context.DisplayName
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small" 
                                           OnClick="@(() => StartEdit(context))" Class="ml-1" />
                        }
                    </MudTd>
                    <MudTd DataLabel="Tenant ID"><MudText Typo="Typo.caption">@context.TenantId</MudText></MudTd>
                    <MudTd DataLabel="Plan">
                        @{
                            var tier = GetTier(context.TenantId);
                        }
                        @if (tier == "P2")
                        {
                            <MudTooltip Text="Microsoft Entra ID P2 — sign-in based features available">
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text">P2</MudChip>
                            </MudTooltip>
                        }
                        else if (tier == "P1")
                        {
                            <MudTooltip Text="Microsoft Entra ID P1 — sign-in based features available">
                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">P1</MudChip>
                            </MudTooltip>
                        }
                        else
                        {
                            <MudTooltip Text="Free tier — sign-in activity & inactive-account analysis require Entra ID P1/P2">
                                <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Text">Free</MudChip>
                            </MudTooltip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Active">
                        <MudSwitch T="bool" Value="context.IsActive" ValueChanged="@(v => ToggleActive(context))" Color="Color.Success" />
                    </MudTd>
                    <MudTd DataLabel="Consent">
                        @if (context.PermissionsCheckedAt == null)
                        {
                            <MudTooltip Text="Permissions not yet checked">
                                <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Color="Color.Default" Size="Size.Small" />
                            </MudTooltip>
                        }
                        else if (string.IsNullOrWhiteSpace(context.MissingPermissions))
                        {
                            <MudTooltip Text="@($"All permissions consented (checked {context.PermissionsCheckedAt:yyyy-MM-dd HH:mm} UTC)")">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                            </MudTooltip>
                        }
                        else
                        {
                            <MudTooltip Text="@($"Missing: {FormatMissingPermissions(context.MissingPermissions)}")">
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.Warning" Variant="Variant.Text">
                                    Re-consent
                                </MudChip>
                            </MudTooltip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Onboarded">@context.OnboardedAt.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd>
                        <MudTooltip Text="Collect data now">
                            <MudIconButton Icon="@Icons.Material.Filled.CloudSync" Color="Color.Success" Size="Size.Small"
                                           Disabled="@(_collectingTenantId == context.TenantId)"
                                           OnClick="@(() => CollectNow(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Check permissions / consent">
                            <MudIconButton Icon="@Icons.Material.Filled.VerifiedUser" Color="Color.Primary" Size="Size.Small"
                                           Disabled="@(_checkingTenantId == context.TenantId)"
                                           OnClick="@(() => CheckPermissions(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Open admin consent URL">
                            <MudIconButton Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Info" Size="Size.Small" 
                                           Href="@GetConsentUrlForTenant(context.TenantId)" Target="_blank" />
                        </MudTooltip>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteTenant(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private List<TenantInfo> _tenants = [];
    private TenantInfo _newTenant = new();
    private Dictionary<string, string> _tiers = new();
    private MudForm _form = null!;
    private bool _loading = true;
    private string _message = string.Empty;
    private Severity _severity = Severity.Info;
    private string _consentTenantId = string.Empty;
    private string _consentUrl = string.Empty;

    private string ClientId => Configuration["AzureAd:ClientId"] ?? string.Empty;
    private string ConsentRedirectUri => Configuration["ConsentCallback:RedirectUri"] ?? $"{NavigationManager.BaseUri.TrimEnd('/')}/consent-complete";

    private bool IsValid => !string.IsNullOrWhiteSpace(_newTenant.TenantId) && !string.IsNullOrWhiteSpace(_newTenant.TenantName);

    protected override async Task OnInitializedAsync()
    {
        await LoadTenants();
    }

    private async Task LoadTenants()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        _tenants = await db.Tenants.OrderBy(t => t.TenantName).ToListAsync();
        var tiers = await DataService.GetTenantEntraIdTiersAsync();
        _tiers = tiers.ToDictionary(t => t.TenantId, t => t.Tier);
        _loading = false;
    }

    private string GetTier(string tenantId) => _tiers.TryGetValue(tenantId, out var t) ? t : "Free";

    private async Task AddTenant()
    {
        if (!IsValid) return;

        await using var db = await DbFactory.CreateDbContextAsync();

        var exists = await db.Tenants.AnyAsync(t => t.TenantId == _newTenant.TenantId);
        if (exists)
        {
            _message = "Tenant with this ID already exists.";
            _severity = Severity.Warning;
            return;
        }

        if (string.IsNullOrWhiteSpace(_newTenant.DisplayName))
            _newTenant.DisplayName = _newTenant.TenantName;

        _newTenant.OnboardedAt = DateTime.UtcNow;
        _newTenant.IsActive = true;

        db.Tenants.Add(_newTenant);
        await db.SaveChangesAsync();

        _message = $"Tenant '{_newTenant.TenantName}' registered successfully.";
        _severity = Severity.Success;
        _newTenant = new TenantInfo();
        await _form.ResetAsync();

        await LoadTenants();
        await TenantFilter.LoadTenantsAsync();

        // Auto-clear the success message after showing it
        _ = Task.Run(async () =>
        {
            await Task.Delay(3000);
            await InvokeAsync(() =>
            {
                _message = string.Empty;
                StateHasChanged();
            });
        });
    }

    private async Task ToggleActive(TenantInfo tenant)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Tenants.FindAsync(tenant.Id);
        if (entity != null)
        {
            entity.IsActive = !entity.IsActive;
            await db.SaveChangesAsync();
        }
        await LoadTenants();
        await TenantFilter.LoadTenantsAsync();
    }

    private async Task DeleteTenant(TenantInfo tenant)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Tenants.FindAsync(tenant.Id);
        if (entity != null)
        {
            db.Tenants.Remove(entity);
            await db.SaveChangesAsync();
        }
        await LoadTenants();
        await TenantFilter.LoadTenantsAsync();
    }

    private string GetConsentUrlForTenant(string tenantId)
    {
        return $"https://login.microsoftonline.com/{Uri.EscapeDataString(tenantId)}/adminconsent" +
               $"?client_id={Uri.EscapeDataString(ClientId)}" +
               $"&redirect_uri={Uri.EscapeDataString(ConsentRedirectUri)}" +
               $"&scope=https://graph.microsoft.com/.default";
    }

    // Renders a comma-separated list of stored permission scopes with their human-readable
    // admin-consent display names, e.g. "Read all users' full profiles (User.Read.All)".
    private static string FormatMissingPermissions(string? missing)
    {
        if (string.IsNullOrWhiteSpace(missing))
            return string.Empty;
        var scopes = missing.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return string.Join(", ", scopes.Select(GraphPermissions.DescribeWithScope));
    }

    private void GenerateConsentUrl()
    {
        if (string.IsNullOrWhiteSpace(_consentTenantId)) return;
        _consentUrl = GetConsentUrlForTenant(_consentTenantId.Trim());
    }

    private async Task CopyConsentUrl()
    {
        // JS interop for clipboard copy
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _consentUrl);
    }

    private string? _collectingTenantId;
    private string? _editingTenantId;
    private string? _checkingTenantId;
    private string _editDisplayName = string.Empty;

    private async Task CollectNow(TenantInfo tenant)
    {
        _collectingTenantId = tenant.TenantId;
        StateHasChanged();

        try
        {
            await DataCollectionService.CollectForTenantAsync(tenant.TenantId, tenant.TenantName);
            _message = $"Data collection completed for '{tenant.TenantName}'.";
            _severity = Severity.Success;
        }
        catch (Exception ex)
        {
            _message = $"Collection failed: {ex.Message}";
            _severity = Severity.Error;
        }
        finally
        {
            _collectingTenantId = null;
        }
    }

    private async Task CheckPermissions(TenantInfo tenant)
    {
        _checkingTenantId = tenant.TenantId;
        StateHasChanged();

        try
        {
            var missing = await GraphService.CheckMissingPermissionsAsync(tenant.TenantId);
            await DataService.UpdateTenantPermissionStatusAsync(tenant.TenantId, missing);

            if (missing.Count == 0)
            {
                _message = $"All permissions consented for '{tenant.TenantName}'.";
                _severity = Severity.Success;
            }
            else
            {
                _message = $"'{tenant.TenantName}' is missing consent for: {string.Join(", ", missing)}.";
                _severity = Severity.Warning;
            }
        }
        catch (Exception ex)
        {
            _message = $"Permission check failed: {ex.Message}";
            _severity = Severity.Error;
        }
        finally
        {
            _checkingTenantId = null;
            await LoadTenants();
        }
    }

    private void StartEdit(TenantInfo tenant)
    {
        _editingTenantId = tenant.TenantId;
        _editDisplayName = tenant.DisplayName;
    }

    private void CancelEdit()
    {
        _editingTenantId = null;
        _editDisplayName = string.Empty;
    }

    private async Task SaveDisplayName(TenantInfo tenant)
    {
        if (string.IsNullOrWhiteSpace(_editDisplayName)) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Tenants.FindAsync(tenant.Id);
        if (entity != null)
        {
            entity.DisplayName = _editDisplayName.Trim();
            await db.SaveChangesAsync();
        }

        _editingTenantId = null;
        _editDisplayName = string.Empty;
        await LoadTenants();
        await TenantFilter.LoadTenantsAsync();
    }
}
