@page "/tenants"
@inject IDbContextFactory<MauDbContext> DbFactory
@inject IConfiguration Configuration
@inject IJSRuntime JS
@inject IDataCollectionService DataCollectionService
@inject IGraphReportService GraphService
@inject IMauDataService DataService
@inject TenantFilterService TenantFilter
@inject NavigationManager NavigationManager
@inject IDialogService DialogService

<BrandedPageTitle Page="Tenant Management" />

@if (!TenantFilter.IsHomeTenantUser)
{
    NavigationManager.NavigateTo("/", replace: true);
    return;
}

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" data-tour="page-header">Tenant Management</MudText>
    <PageTour PageKey="tenants" />
</div>

@{
    var tenantsNeedingConsent = _tenants.Where(t => !string.IsNullOrWhiteSpace(t.MissingPermissions)).ToList();
}
@if (tenantsNeedingConsent.Count > 0)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4" Icon="@Icons.Material.Filled.GppMaybe">
        <MudText Typo="Typo.subtitle2">Re-consent required</MudText>
        <MudText Typo="Typo.body2" Class="mb-2">
            @tenantsNeedingConsent.Count tenant@(tenantsNeedingConsent.Count == 1 ? "" : "s") @(tenantsNeedingConsent.Count == 1 ? "is" : "are")
            missing consent for one or more Graph permissions. Some data will not be collected until the customer's Global Admin re-runs admin consent.
        </MudText>
        <MudList T="string" Dense="true">
            @foreach (var t in tenantsNeedingConsent)
            {
                <MudListItem T="string" Icon="@Icons.Material.Filled.Warning" IconColor="Color.Warning">
                    <strong>@t.DisplayName</strong> — missing: @FormatMissingPermissions(t.MissingPermissions)
                    <MudLink Href="@GetConsentUrlForTenant(t.TenantId)" Target="_blank" Class="ml-2">Open consent link</MudLink>
                </MudListItem>
            }
        </MudList>
    </MudAlert>
}

<MudGrid>
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Register New Tenant</MudText>
            <MudForm @ref="_form">
                <MudTextField @bind-Value="_newTenant.TenantId" Label="Tenant ID (GUID)" Required="true" Class="mb-3" />
                <MudTextField @bind-Value="_newTenant.TenantName" Label="Tenant Name" Required="true" Class="mb-3" />
                <MudTextField @bind-Value="_newTenant.DisplayName" Label="Display Name" Class="mb-3" />
            </MudForm>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddTenant" Disabled="@(!IsValid)">
                Add Tenant
            </MudButton>
            @if (!string.IsNullOrEmpty(_message))
            {
                <MudAlert Severity="@_severity" Class="mt-3">@_message</MudAlert>
            }
        </MudPaper>

        <MudPaper Class="pa-4 mt-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Admin Consent Link Generator</MudText>
            <MudText Typo="Typo.body2" Class="mb-3">
                Generate a consent URL for a tenant admin to authorize this application.
                Send this link to the customer's Global Admin.
            </MudText>
            <MudTextField @bind-Value="_consentTenantId" Label="Target Tenant ID (GUID)" Class="mb-3" />
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="GenerateConsentUrl" 
                       Disabled="@string.IsNullOrWhiteSpace(_consentTenantId)">
                Generate URL
            </MudButton>
            @if (!string.IsNullOrEmpty(_consentUrl))
            {
                <MudAlert Severity="Severity.Info" Class="mt-3">
                    <MudText Typo="Typo.body2" Class="mb-1">Send this URL to the tenant admin:</MudText>
                    <MudLink Href="@_consentUrl" Target="_blank" Typo="Typo.caption" Style="word-break: break-all;">
                        @_consentUrl
                    </MudLink>
                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" 
                               OnClick="CopyConsentUrl" Class="mt-2">
                        Copy to clipboard
                    </MudButton>
                </MudAlert>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4" Elevation="2">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6">Registered Tenants</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.CloudSync"
                           OnClick="CollectAll" Disabled="@(_collectingAll || _collectingTenantId != null)"
                           data-tour="page-action">
                    @(_collectingAll ? "Collecting…" : "Collect All Tenants")
                </MudButton>
            </div>

            @if (_collectingAll || _collectAllItems.Count > 0)
            {
                <MudPaper Class="pa-3 mb-3" Elevation="0" Outlined="true">
                    @if (_collectingAll)
                    {
                        <div class="d-flex align-center mb-2">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Success" Class="mr-2" />
                            <MudText Typo="Typo.body2">
                                Collecting in parallel — <strong>@_collectAllDone</strong> of <strong>@_collectAllTotal</strong> done,
                                <strong>@_collectAllItems.Count(i => i.Status == CollectStatus.Collecting)</strong> in progress
                            </MudText>
                        </div>
                        <MudProgressLinear Color="Color.Success" Value="@(_collectAllTotal == 0 ? 0 : (double)_collectAllDone / _collectAllTotal * 100)" Class="mb-2" />
                    }
                    else
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2">
                            Collection finished — @_collectAllItems.Count(i => i.Status == CollectStatus.Success) of @_collectAllItems.Count succeeded
                        </MudText>
                    }
                    <MudList T="string" Dense="true">
                        @foreach (var item in _collectAllItems)
                        {
                            <MudListItem T="string"
                                         Icon="@StatusIcon(item.Status)"
                                         IconColor="@StatusColor(item.Status)">
                                <strong>@item.Name</strong>
                                @switch (item.Status)
                                {
                                    case CollectStatus.Pending:
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-inline ml-1">queued…</MudText>
                                        break;
                                    case CollectStatus.Collecting:
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Info" Class="ml-2" Style="height:14px;width:14px;" />
                                        <MudText Typo="Typo.caption" Color="Color.Info" Class="d-inline ml-1">collecting…</MudText>
                                        break;
                                    case CollectStatus.Success:
                                        <text> — collected</text>
                                        break;
                                    case CollectStatus.Failed:
                                        <text> — failed: @item.Error</text>
                                        break;
                                }
                            </MudListItem>
                        }
                    </MudList>
                </MudPaper>
            }

            <MudTable Items="_tenants" Dense="true" Hover="true" Loading="_loading">
                <HeaderContent>
                    <MudTh>Tenant Name</MudTh>
                    <MudTh>Tenant ID</MudTh>
                    <MudTh>Plan</MudTh>
                    <MudTh>Defender</MudTh>
                    <MudTh>Active</MudTh>
                    <MudTh>Consent</MudTh>
                    <MudTh>Onboarded</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        @if (_editingTenantId == context.TenantId)
                        {
                            <MudTextField @bind-Value="_editDisplayName" Variant="Variant.Outlined" Margin="Margin.Dense" 
                                          Immediate="true" Style="max-width: 200px; display: inline-block;" />
                            <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" 
                                           OnClick="@(() => SaveDisplayName(context))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" Size="Size.Small" 
                                           OnClick="CancelEdit" />
                        }
                        else
                        {
                            @context.DisplayName
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small" 
                                           OnClick="@(() => StartEdit(context))" Class="ml-1" />
                        }
                    </MudTd>
                    <MudTd DataLabel="Tenant ID"><MudText Typo="Typo.caption">@context.TenantId</MudText></MudTd>
                    <MudTd DataLabel="Plan">
                        @{
                            var tier = GetTier(context.TenantId);
                        }
                        @if (tier == "P2")
                        {
                            <MudTooltip Text="Microsoft Entra ID P2 — sign-in based features available">
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text">P2</MudChip>
                            </MudTooltip>
                        }
                        else if (tier == "P1")
                        {
                            <MudTooltip Text="Microsoft Entra ID P1 — sign-in based features available">
                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">P1</MudChip>
                            </MudTooltip>
                        }
                        else
                        {
                            <MudTooltip Text="Free tier — sign-in activity & inactive-account analysis require Entra ID P1/P2">
                                <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Text">Free</MudChip>
                            </MudTooltip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Defender">
                        @{
                            var mdo = GetDefenderTier(context.TenantId);
                        }
                        @if (mdo == "MDO P2")
                        {
                            <MudTooltip Text="Microsoft Defender for Office 365 Plan 2 — email threat protection + Attack Simulation Training">
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text">MDO P2</MudChip>
                            </MudTooltip>
                        }
                        else if (mdo == "MDO P1")
                        {
                            <MudTooltip Text="Microsoft Defender for Office 365 Plan 1 — email threat protection (no Attack Simulation Training)">
                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">MDO P1</MudChip>
                            </MudTooltip>
                        }
                        else
                        {
                            <MudTooltip Text="Not licensed — email threat protection & Attack Simulation Training require Defender for Office 365 P1/P2">
                                <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Text">Not licensed</MudChip>
                            </MudTooltip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Active">
                        <MudTooltip Text="Active: collected on schedule (cron Job, Copilot-audit cron, Collect All) and users from this tenant can sign in. Deactivate to exclude it from collection and block sign-in — all data is kept.">
                            <MudSwitch T="bool" Value="context.IsActive" ValueChanged="@(v => ToggleActive(context))" Color="Color.Success" />
                        </MudTooltip>
                    </MudTd>
                    <MudTd DataLabel="Consent">
                        @if (context.PermissionsCheckedAt == null)
                        {
                            <MudTooltip Text="Permissions not yet checked">
                                <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Color="Color.Default" Size="Size.Small" />
                            </MudTooltip>
                        }
                        else if (string.IsNullOrWhiteSpace(context.MissingPermissions))
                        {
                            <MudTooltip Text="@($"All permissions consented (checked {context.PermissionsCheckedAt:yyyy-MM-dd HH:mm} UTC)")">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                            </MudTooltip>
                        }
                        else
                        {
                            <MudTooltip Text="@($"Missing: {FormatMissingPermissions(context.MissingPermissions)}")">
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.Warning" Variant="Variant.Text">
                                    Re-consent
                                </MudChip>
                            </MudTooltip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Onboarded">@context.OnboardedAt.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd>
                        <MudTooltip Text="Collect data now">
                            <MudIconButton Icon="@Icons.Material.Filled.CloudSync" Color="Color.Success" Size="Size.Small"
                                           Disabled="@(_collectingTenantId == context.TenantId)"
                                           OnClick="@(() => CollectNow(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Check permissions / consent">
                            <MudIconButton Icon="@Icons.Material.Filled.VerifiedUser" Color="Color.Primary" Size="Size.Small"
                                           Disabled="@(_checkingTenantId == context.TenantId)"
                                           OnClick="@(() => CheckPermissions(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Open admin consent URL">
                            <MudIconButton Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Info" Size="Size.Small" 
                                           Href="@GetConsentUrlForTenant(context.TenantId)" Target="_blank" />
                        </MudTooltip>
                        <MudTooltip Text="Purge ALL historical data for this tenant across every dashboard (keeps the registration). Permanent — cannot be undone.">
                            <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep" Color="Color.Error" Size="Size.Small"
                                           Disabled="@(_purgingTenantId == context.TenantId)"
                                           OnClick="@(() => PurgeTenant(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Remove the tenant registration only. Historical data is kept (orphaned) and re-appears if the tenant is re-onboarded with the same ID. Use Purge to delete the data.">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteTenant(context))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private List<TenantInfo> _tenants = [];
    private TenantInfo _newTenant = new();
    private Dictionary<string, string> _tiers = new();
    private Dictionary<string, string> _defenderTiers = new();
    private MudForm _form = null!;
    private bool _loading = true;
    private string _message = string.Empty;
    private Severity _severity = Severity.Info;
    private string _consentTenantId = string.Empty;
    private string _consentUrl = string.Empty;

    private string ClientId => Configuration["AzureAd:ClientId"] ?? string.Empty;
    // Consent completion is hosted on the Static Web App; the URL is injected via ConsentCallback:RedirectUri at deploy time.
    private string ConsentRedirectUri => Configuration["ConsentCallback:RedirectUri"] ?? string.Empty;

    private bool IsValid => !string.IsNullOrWhiteSpace(_newTenant.TenantId) && !string.IsNullOrWhiteSpace(_newTenant.TenantName);

    protected override async Task OnInitializedAsync()
    {
        await LoadTenants();
    }

    private async Task LoadTenants()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        _tenants = await db.Tenants.OrderBy(t => t.TenantName).ToListAsync();
        var tiers = await DataService.GetTenantEntraIdTiersAsync();
        _tiers = tiers.ToDictionary(t => t.TenantId, t => t.Tier);
        var defenderTiers = await DataService.GetTenantDefenderTiersAsync();
        _defenderTiers = defenderTiers.ToDictionary(t => t.TenantId, t => t.Tier);
        _loading = false;
    }

    private string GetTier(string tenantId) => _tiers.TryGetValue(tenantId, out var t) ? t : "Free";

    private string GetDefenderTier(string tenantId) => _defenderTiers.TryGetValue(tenantId, out var t) ? t : "None";

    private async Task AddTenant()
    {
        if (!IsValid) return;

        await using var db = await DbFactory.CreateDbContextAsync();

        var exists = await db.Tenants.AnyAsync(t => t.TenantId == _newTenant.TenantId);
        if (exists)
        {
            _message = "Tenant with this ID already exists.";
            _severity = Severity.Warning;
            return;
        }

        if (string.IsNullOrWhiteSpace(_newTenant.DisplayName))
            _newTenant.DisplayName = _newTenant.TenantName;

        _newTenant.OnboardedAt = DateTime.UtcNow;
        _newTenant.IsActive = true;

        db.Tenants.Add(_newTenant);
        await db.SaveChangesAsync();

        _message = $"Tenant '{_newTenant.TenantName}' registered successfully.";
        _severity = Severity.Success;
        _newTenant = new TenantInfo();
        await _form.ResetAsync();

        await LoadTenants();
        await TenantFilter.LoadTenantsAsync();

        // Auto-clear the success message after showing it
        _ = Task.Run(async () =>
        {
            await Task.Delay(3000);
            await InvokeAsync(() =>
            {
                _message = string.Empty;
                StateHasChanged();
            });
        });
    }

    private async Task ToggleActive(TenantInfo tenant)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Tenants.FindAsync(tenant.Id);
        if (entity != null)
        {
            entity.IsActive = !entity.IsActive;
            await db.SaveChangesAsync();
        }
        await LoadTenants();
        await TenantFilter.LoadTenantsAsync();
    }

    private async Task DeleteTenant(TenantInfo tenant)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Tenants.FindAsync(tenant.Id);
        if (entity != null)
        {
            db.Tenants.Remove(entity);
            await db.SaveChangesAsync();
        }
        await LoadTenants();
        await TenantFilter.LoadTenantsAsync();
    }

    private async Task PurgeTenant(TenantInfo tenant)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Purge all historical data?",
            (MarkupString)(
                $"This permanently deletes <strong>ALL</strong> collected snapshot history for " +
                $"<strong>{tenant.TenantName}</strong> across every dashboard — usage, licenses, security, " +
                "identity, governance and threat data.<br /><br />" +
                "<strong>This cannot be undone.</strong> The tenant registration is kept, so future " +
                "collections will start rebuilding history from scratch."),
            yesText: "Purge all data",
            cancelText: "Cancel");

        if (confirmed != true) return;

        _purgingTenantId = tenant.TenantId;
        _message = string.Empty;
        StateHasChanged();
        try
        {
            var deleted = await DataService.PurgeTenantDataAsync(tenant.TenantId);
            _message = $"Purged {deleted:N0} historical record(s) for '{tenant.TenantName}'.";
            _severity = Severity.Success;
            await TenantFilter.LoadTenantsAsync();
        }
        catch (Exception ex)
        {
            _message = $"Failed to purge data for '{tenant.TenantName}': {ex.Message}";
            _severity = Severity.Error;
        }
        finally
        {
            _purgingTenantId = null;
            StateHasChanged();
        }
    }

    private string GetConsentUrlForTenant(string tenantId)
    {
        return $"https://login.microsoftonline.com/{Uri.EscapeDataString(tenantId)}/adminconsent" +
               $"?client_id={Uri.EscapeDataString(ClientId)}" +
               $"&redirect_uri={Uri.EscapeDataString(ConsentRedirectUri)}" +
               $"&scope=https://graph.microsoft.com/.default";
    }

    // Renders a comma-separated list of stored permission scopes with their human-readable
    // admin-consent display names, e.g. "Read all users' full profiles (User.Read.All)".
    private static string FormatMissingPermissions(string? missing)
    {
        if (string.IsNullOrWhiteSpace(missing))
            return string.Empty;
        var scopes = missing.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return string.Join(", ", scopes.Select(GraphPermissions.DescribeWithScope));
    }

    private void GenerateConsentUrl()
    {
        if (string.IsNullOrWhiteSpace(_consentTenantId)) return;
        _consentUrl = GetConsentUrlForTenant(_consentTenantId.Trim());
    }

    private async Task CopyConsentUrl()
    {
        // JS interop for clipboard copy
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _consentUrl);
    }

    private string? _collectingTenantId;
    private string? _editingTenantId;
    private string? _checkingTenantId;
    private string? _purgingTenantId;
    private string _editDisplayName = string.Empty;

    // Collect-all progress state
    private bool _collectingAll;
    private int _collectAllDone;
    private int _collectAllTotal;
    private readonly List<CollectItem> _collectAllItems = [];
    private readonly object _collectLock = new();

    // Max tenants collected concurrently. The Collector container scales independently
    // (0→3 replicas × 5 concurrent requests) so parallel collection is safe; bound it to
    // avoid issuing more in-flight requests than the collector can usefully absorb.
    private int MaxParallelCollections =>
        int.TryParse(Configuration["Collector:MaxParallelCollections"], out var n) && n > 0 ? n : 4;

    private enum CollectStatus { Pending, Collecting, Success, Failed }

    private sealed class CollectItem
    {
        public required string TenantId { get; init; }
        public required string Name { get; init; }
        public CollectStatus Status { get; set; } = CollectStatus.Pending;
        public string? Error { get; set; }
    }

    private static string StatusIcon(CollectStatus s) => s switch
    {
        CollectStatus.Success => Icons.Material.Filled.CheckCircle,
        CollectStatus.Failed => Icons.Material.Filled.Error,
        CollectStatus.Collecting => Icons.Material.Filled.Sync,
        _ => Icons.Material.Filled.Schedule
    };

    private static Color StatusColor(CollectStatus s) => s switch
    {
        CollectStatus.Success => Color.Success,
        CollectStatus.Failed => Color.Error,
        CollectStatus.Collecting => Color.Info,
        _ => Color.Default
    };

    private async Task CollectNow(TenantInfo tenant)
    {
        _collectingTenantId = tenant.TenantId;
        StateHasChanged();

        try
        {
            await DataCollectionService.CollectForTenantAsync(tenant.TenantId, tenant.TenantName);
            _message = $"Data collection completed for '{tenant.TenantName}'.";
            _severity = Severity.Success;
        }
        catch (Exception ex)
        {
            _message = $"Collection failed: {ex.Message}";
            _severity = Severity.Error;
        }
        finally
        {
            _collectingTenantId = null;
        }
    }

    // Collects data for every active tenant in parallel (bounded concurrency), surfacing live
    // per-tenant status (queued → collecting → collected/failed), an aggregate progress bar,
    // and a final overall summary. UI updates are marshaled back onto the Blazor circuit via
    // InvokeAsync because the collection tasks run on background threads.
    private async Task CollectAll()
    {
        var active = _tenants.Where(t => t.IsActive).ToList();
        if (active.Count == 0)
        {
            _message = "No active tenants to collect.";
            _severity = Severity.Warning;
            return;
        }

        _collectingAll = true;
        _collectAllItems.Clear();
        _collectAllItems.AddRange(active.Select(t => new CollectItem { TenantId = t.TenantId, Name = t.TenantName }));
        _collectAllDone = 0;
        _collectAllTotal = active.Count;
        _message = string.Empty;
        StateHasChanged();

        using var throttle = new SemaphoreSlim(MaxParallelCollections);

        var tasks = active.Select(async tenant =>
        {
            var item = _collectAllItems.First(i => i.TenantId == tenant.TenantId);
            await throttle.WaitAsync();
            try
            {
                item.Status = CollectStatus.Collecting;
                await InvokeAsync(StateHasChanged);

                await DataCollectionService.CollectForTenantAsync(tenant.TenantId, tenant.TenantName);
                item.Status = CollectStatus.Success;
            }
            catch (Exception ex)
            {
                item.Status = CollectStatus.Failed;
                item.Error = ex.Message;
            }
            finally
            {
                throttle.Release();
                lock (_collectLock) { _collectAllDone++; }
                await InvokeAsync(StateHasChanged);
            }
        });

        await Task.WhenAll(tasks);

        _collectingAll = false;
        var failures = _collectAllItems.Count(i => i.Status == CollectStatus.Failed);
        _message = failures == 0
            ? $"Data collection completed for all {_collectAllTotal} active tenant(s)."
            : $"Collection finished: {_collectAllTotal - failures} succeeded, {failures} failed.";
        _severity = failures == 0 ? Severity.Success : Severity.Warning;
        StateHasChanged();
    }

    private async Task CheckPermissions(TenantInfo tenant)
    {
        _checkingTenantId = tenant.TenantId;
        StateHasChanged();

        try
        {
            var missing = await GraphService.CheckMissingPermissionsAsync(tenant.TenantId);
            await DataService.UpdateTenantPermissionStatusAsync(tenant.TenantId, missing);

            if (missing.Count == 0)
            {
                _message = $"All permissions consented for '{tenant.TenantName}'.";
                _severity = Severity.Success;
            }
            else
            {
                _message = $"'{tenant.TenantName}' is missing consent for: {string.Join(", ", missing)}.";
                _severity = Severity.Warning;
            }
        }
        catch (Exception ex)
        {
            _message = $"Permission check failed: {ex.Message}";
            _severity = Severity.Error;
        }
        finally
        {
            _checkingTenantId = null;
            await LoadTenants();
        }
    }

    private void StartEdit(TenantInfo tenant)
    {
        _editingTenantId = tenant.TenantId;
        _editDisplayName = tenant.DisplayName;
    }

    private void CancelEdit()
    {
        _editingTenantId = null;
        _editDisplayName = string.Empty;
    }

    private async Task SaveDisplayName(TenantInfo tenant)
    {
        if (string.IsNullOrWhiteSpace(_editDisplayName)) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Tenants.FindAsync(tenant.Id);
        if (entity != null)
        {
            entity.DisplayName = _editDisplayName.Trim();
            await db.SaveChangesAsync();
        }

        _editingTenantId = null;
        _editDisplayName = string.Empty;
        await LoadTenants();
        await TenantFilter.LoadTenantsAsync();
    }
}
