@page "/m365apps"
@using ApexCharts
@using Color = MudBlazor.Color
@using Size = MudBlazor.Size
@inject IMauDataService MauDataService
@inject TenantFilterService TenantFilter
@implements IDisposable

<BrandedPageTitle Page="M365 Apps" />

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    <div class="d-flex flex-column align-center justify-center" style="min-height: 400px;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-4">Loading M365 App usage data...</MudText>
    </div>
}
else
{
<MudGrid>
    <MudItem xs="12">
        <div class="d-flex justify-space-between align-center">
            <MudText Typo="Typo.h5">M365 App Platform Usage</MudText>
            <ExportButton Feature="m365apps" />
        </div>
    </MudItem>

    @* App Usage Bar Chart *@
    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Users by Application</MudText>
            @if (_appChartData.Count > 0)
            {
                <ApexChart TItem="AppDataPoint"
                           Options="_appChartOptions"
                           Height="350"
                           @key="_chartKey">
                    @foreach (var series in _appChartData)
                    {
                        <ApexPointSeries TItem="AppDataPoint"
                                         Items="series.Value"
                                         Name="@series.Key"
                                         SeriesType="SeriesType.Bar"
                                         XValue="@(e => e.Label)"
                                         YValue="@(e => (decimal?)e.Count)" />
                    }
                </ApexChart>
            }
            else
            {
                <MudText Color="Color.Secondary">No app usage data available. Refresh tenant data to collect.</MudText>
            }
        </MudPaper>
    </MudItem>

    @* Platform Usage Donut *@
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Users by Platform</MudText>
            @if (TenantFilter.IsMultiTenantView && _platformChartData.Count > 0)
            {
                <ApexChart TItem="AppDataPoint"
                           Options="_platformBarOptions"
                           Height="350"
                           @key="_chartKey">
                    @foreach (var series in _platformChartData)
                    {
                        <ApexPointSeries TItem="AppDataPoint"
                                         Items="series.Value"
                                         Name="@series.Key"
                                         SeriesType="SeriesType.Bar"
                                         XValue="@(e => e.Label)"
                                         YValue="@(e => (decimal?)e.Count)" />
                    }
                </ApexChart>
            }
            else if (_platformData.Count > 0)
            {
                <ApexChart TItem="AppDataPoint"
                           Options="_platformChartOptions"
                           Height="350"
                           @key="_chartKey">
                    <ApexPointSeries TItem="AppDataPoint"
                                     Items="_platformData"
                                     Name="Users"
                                     SeriesType="SeriesType.Donut"
                                     XValue="@(e => e.Label)"
                                     YValue="@(e => (decimal?)e.Count)" />
                </ApexChart>
            }
            else
            {
                <MudText Color="Color.Secondary">No platform data available.</MudText>
            }
        </MudPaper>
    </MudItem>

    @* Detailed Table *@
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">App Usage Details</MudText>
            @if (_tableData.Count > 0)
            {
                <MudTable Items="_tableData" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm"
                          SortLabel="Sort By" FixedHeader="true" GroupBy="_groupDefinition">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<AppTableRow, object>(x => x.AppName)">Application</MudTableSortLabel></MudTh>
                        @if (TenantFilter.IsMultiTenantView)
                        {
                            <MudTh><MudTableSortLabel SortBy="new Func<AppTableRow, object>(x => x.TenantName)">Tenant</MudTableSortLabel></MudTh>
                        }
                        <MudTh><MudTableSortLabel SortBy="new Func<AppTableRow, object>(x => x.UserCount)" InitialDirection="SortDirection.Descending">Users</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AppTableRow, object>(x => x.ReportDate)">Report Date</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <GroupHeaderTemplate>
                        <MudTh Class="mud-table-cell-custom-group" colspan="@(_groupColspan)">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Class="mr-2" />
                            <b>@context.Key</b>
                        </MudTh>
                    </GroupHeaderTemplate>
                    <RowTemplate>
                        <MudTd DataLabel="Application"><b>@context.AppName</b></MudTd>
                        @if (TenantFilter.IsMultiTenantView)
                        {
                            <MudTd DataLabel="Tenant">
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">@context.TenantName</MudChip>
                            </MudTd>
                        }
                        <MudTd DataLabel="Users">@context.UserCount.ToString("N0")</MudTd>
                        <MudTd DataLabel="Report Date">@context.ReportDate.ToString("yyyy-MM-dd")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudText Color="Color.Secondary">No data available.</MudText>
            }
        </MudPaper>
    </MudItem>

    @* App x Platform Adoption Matrix (from anonymized per-user detail) *@
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6">App &times; Platform Adoption</MudText>
                <ExportMenu Items="_exportItems" />
            </div>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                Active users per application and platform, derived from per-user activity. User identities are anonymized (irreversible per-tenant pseudonyms) &mdash; no UPNs or names are stored.
            </MudText>
            @if (_appPlatformMatrix.Count > 0)
            {
                <MudSimpleTable Dense="true" Hover="true" Striped="true">
                    <thead>
                        <tr>
                            @if (TenantFilter.IsMultiTenantView)
                            {
                                <th>Tenant</th>
                            }
                            <th>Application</th>
                            <th style="text-align:right">Windows</th>
                            <th style="text-align:right">Mac</th>
                            <th style="text-align:right">Mobile</th>
                            <th style="text-align:right">Web</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _appPlatformMatrix)
                        {
                            <tr>
                                @if (TenantFilter.IsMultiTenantView)
                                {
                                    <td>@row.TenantName</td>
                                }
                                <td><b>@row.AppName</b></td>
                                <td style="text-align:right">@row.Windows.ToString("N0")</td>
                                <td style="text-align:right">@row.Mac.ToString("N0")</td>
                                <td style="text-align:right">@row.Mobile.ToString("N0")</td>
                                <td style="text-align:right">@row.Web.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
            else
            {
                <MudText Color="Color.Secondary">No per-user detail available. Refresh tenant data to collect.</MudText>
            }
        </MudPaper>
    </MudItem>

    @* Office Desktop Activations by Product & Device *@
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Office Desktop Activations by Product &amp; Device</MudText>
            @if (_activationData.Count > 0)
            {
                <ApexChart TItem="ActivationDataPoint"
                           Options="_activationChartOptions"
                           Height="350"
                           @key="_chartKey">
                    @foreach (var series in _activationData)
                    {
                        <ApexPointSeries TItem="ActivationDataPoint"
                                         Items="series.Value"
                                         Name="@series.Key"
                                         SeriesType="SeriesType.Bar"
                                         XValue="@(e => e.Product)"
                                         YValue="@(e => (decimal?)e.Count)" />
                    }
                </ApexChart>
            }
            else
            {
                <MudText Color="Color.Secondary">No activation data available. Refresh tenant data to collect.</MudText>
            }
        </MudPaper>
    </MudItem>
</MudGrid>
}

@code {
    private bool _loading = true;
    private string _chartKey = Guid.NewGuid().ToString();
    private Dictionary<string, List<AppDataPoint>> _appChartData = [];
    private List<AppDataPoint> _platformData = [];
    private Dictionary<string, List<AppDataPoint>> _platformChartData = [];
    private List<AppTableRow> _tableData = [];
    private TableGroupDefinition<AppTableRow>? _groupDefinition;
    private int _groupColspan = 3;

    private List<AppPlatformRow> _appPlatformMatrix = [];
    private Dictionary<string, List<ActivationDataPoint>> _activationData = [];

    private readonly (string Label, string Feature)[] _exportItems =
    [
        ("App x Platform Detail (anonymized)", "m365app-userdetail"),
        ("Office Activations (counts)", "office-activations"),
        ("Office Activations (anonymized users)", "office-activation-users"),
    ];

    private ApexChartOptions<ActivationDataPoint> _activationChartOptions = new()
    {
        Legend = new Legend { Show = true, Position = LegendPosition.Bottom },
        Chart = new Chart { ForeColor = "var(--mud-palette-text-primary)", Stacked = false },
        Xaxis = new XAxis { Categories = new List<string>() }
    };

    private ApexChartOptions<AppDataPoint> _appChartOptions = new()
    {
        PlotOptions = new PlotOptions
        {
            Bar = new PlotOptionsBar { Horizontal = true }
        },
        Legend = new Legend { Show = true, Position = LegendPosition.Bottom },
        Chart = new Chart { ForeColor = "var(--mud-palette-text-primary)" },
        Xaxis = new XAxis { Categories = new List<string>() }
    };

    private ApexChartOptions<AppDataPoint> _platformChartOptions = new()
    {
        Legend = new Legend { Show = true, Position = LegendPosition.Bottom },
        Chart = new Chart { ForeColor = "var(--mud-palette-text-primary)" }
    };

    private ApexChartOptions<AppDataPoint> _platformBarOptions = new()
    {
        Legend = new Legend { Show = true, Position = LegendPosition.Bottom },
        Chart = new Chart { ForeColor = "var(--mud-palette-text-primary)" },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = false } },
        Xaxis = new XAxis { Categories = new List<string>() }
    };

    protected override async Task OnInitializedAsync()
    {
        TenantFilter.OnChangeAsync += OnTenantFilterChangedAsync;
        await LoadData();
    }

    private Task OnTenantFilterChangedAsync()
    {
        return InvokeAsync(async () =>
        {
            TenantFilter.SetLoading(true);
            _loading = true;
            StateHasChanged();
            await LoadData();
            TenantFilter.SetLoading(false);
            StateHasChanged();
        });
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();

        var tenantIds = TenantFilter.GetFilteredTenantIds();
        var data = await MauDataService.GetM365AppUsageAsync(tenantIds);

        var latest = data
            .GroupBy(d => new { d.TenantId, d.AppName, d.Platform })
            .Select(g => g.OrderByDescending(x => x.ReportDate).First())
            .ToList();

        // App chart: filter to app-level rows (Platform == "All")
        var appRows = latest.Where(d => d.Platform == "All" && d.AppName != "All").ToList();

        // Build a consistent set of all app names across all tenants
        var allAppNames = appRows.Select(d => d.AppName).Distinct().OrderBy(n => n).ToList();
        _appChartOptions.Xaxis = new XAxis { Categories = allAppNames };

        _appChartData = [];
        if (TenantFilter.IsMultiTenantView)
        {
            foreach (var group in appRows.GroupBy(d => TenantFilter.GetTenantName(d.TenantId)))
            {
                var seriesData = allAppNames.Select(app =>
                {
                    var match = group.FirstOrDefault(d => d.AppName == app);
                    return new AppDataPoint { Label = app, Count = match?.UserCount ?? 0 };
                }).ToList();
                _appChartData[group.Key] = seriesData;
            }
        }
        else
        {
            _appChartData["Users"] = allAppNames.Select(app =>
            {
                var match = appRows.FirstOrDefault(d => d.AppName == app);
                return new AppDataPoint { Label = app, Count = match?.UserCount ?? 0 };
            }).ToList();
        }

        // Platform donut: aggregate across tenants
        var platformRows = latest.Where(d => d.AppName == "All" && d.Platform != "All").ToList();
        _platformData = platformRows
            .GroupBy(d => d.Platform)
            .Select(g => new AppDataPoint { Label = g.Key, Count = g.Sum(x => x.UserCount) })
            .OrderByDescending(d => d.Count)
            .ToList();

        // Multi-tenant: one bar series per tenant, categories = platforms.
        _platformChartData = [];
        if (TenantFilter.IsMultiTenantView)
        {
            var allPlatforms = platformRows.Select(d => d.Platform).Distinct().OrderBy(p => p).ToList();
            _platformBarOptions.Xaxis = new XAxis { Categories = allPlatforms };
            foreach (var group in platformRows.GroupBy(d => TenantFilter.GetTenantName(d.TenantId)).OrderBy(g => g.Key))
            {
                _platformChartData[group.Key] = allPlatforms.Select(p => new AppDataPoint
                {
                    Label = p,
                    Count = group.Where(d => d.Platform == p).Sum(d => d.UserCount)
                }).ToList();
            }
        }

        // Table data: app-level detail
        _tableData = appRows.Select(d => new AppTableRow
        {
            AppName = d.AppName,
            TenantName = TenantFilter.GetTenantName(d.TenantId),
            UserCount = d.UserCount,
            ReportDate = d.ReportDate
        }).OrderByDescending(d => d.UserCount).ToList();

        // Group the details table by tenant in multi-tenant view for easier scanning
        if (TenantFilter.IsMultiTenantView)
        {
            _groupDefinition = new TableGroupDefinition<AppTableRow>
            {
                Selector = x => x.TenantName,
                GroupName = "Tenant",
                Expandable = true,
                IsInitiallyExpanded = true
            };
            _groupColspan = 4; // Application + Tenant + Users + Report Date
        }
        else
        {
            _groupDefinition = null;
            _groupColspan = 3;
        }

        // App x Platform adoption matrix (anonymized per-user detail aggregated to counts)
        var userDetail = await MauDataService.GetM365AppUserDetailAsync(tenantIds);
        _appPlatformMatrix = BuildAppPlatformMatrix(userDetail);

        // Office desktop activations by product & device
        var activations = await MauDataService.GetOffice365ActivationsAsync(tenantIds);
        BuildActivationChart(activations);

        _chartKey = Guid.NewGuid().ToString();
        _loading = false;
    }

    private List<AppPlatformRow> BuildAppPlatformMatrix(List<M365AppUserDetailSnapshot> detail)
    {
        if (detail.Count == 0) return [];

        if (TenantFilter.IsMultiTenantView)
        {
            var rows = new List<AppPlatformRow>();
            foreach (var g in detail.GroupBy(d => d.TenantId).OrderBy(g => TenantFilter.GetTenantName(g.Key)))
            {
                rows.AddRange(BuildMatrixForSet(g.ToList(), TenantFilter.GetTenantName(g.Key)));
            }
            return rows;
        }

        return BuildMatrixForSet(detail, string.Empty);
    }

    private static List<AppPlatformRow> BuildMatrixForSet(List<M365AppUserDetailSnapshot> detail, string tenantName)
    {
        AppPlatformRow Row(string app, Func<M365AppUserDetailSnapshot, bool> win,
            Func<M365AppUserDetailSnapshot, bool> mac, Func<M365AppUserDetailSnapshot, bool> mob,
            Func<M365AppUserDetailSnapshot, bool> web) => new()
        {
            TenantName = tenantName,
            AppName = app,
            Windows = detail.Count(win),
            Mac = detail.Count(mac),
            Mobile = detail.Count(mob),
            Web = detail.Count(web)
        };

        return
        [
            Row("Outlook", x => x.OutlookWindows, x => x.OutlookMac, x => x.OutlookMobile, x => x.OutlookWeb),
            Row("Word", x => x.WordWindows, x => x.WordMac, x => x.WordMobile, x => x.WordWeb),
            Row("Excel", x => x.ExcelWindows, x => x.ExcelMac, x => x.ExcelMobile, x => x.ExcelWeb),
            Row("PowerPoint", x => x.PowerPointWindows, x => x.PowerPointMac, x => x.PowerPointMobile, x => x.PowerPointWeb),
            Row("OneNote", x => x.OneNoteWindows, x => x.OneNoteMac, x => x.OneNoteMobile, x => x.OneNoteWeb),
            Row("Teams", x => x.TeamsWindows, x => x.TeamsMac, x => x.TeamsMobile, x => x.TeamsWeb),
        ];
    }

    private void BuildActivationChart(List<Office365ActivationSnapshot> activations)
    {
        _activationData = [];
        if (activations.Count == 0)
        {
            _activationChartOptions.Xaxis = new XAxis { Categories = new List<string>() };
            return;
        }

        // Single-tenant: categories are products. Multi-tenant: categories are "Tenant · Product"
        // so each tenant's activations are distinguishable on the same chart.
        var grouped = TenantFilter.IsMultiTenantView
            ? activations
                .GroupBy(a => new { a.TenantId, a.ProductType })
                .Select(g => new
                {
                    Label = $"{TenantFilter.GetTenantName(g.Key.TenantId)} · {g.Key.ProductType}",
                    Windows = g.Sum(x => x.WindowsCount),
                    Mac = g.Sum(x => x.MacCount),
                    Android = g.Sum(x => x.AndroidCount),
                    Ios = g.Sum(x => x.IosCount),
                    WindowsMobile = g.Sum(x => x.WindowsMobileCount)
                })
                .OrderBy(p => p.Label)
                .ToList()
            : activations
                .GroupBy(a => a.ProductType)
                .Select(g => new
                {
                    Label = g.Key,
                    Windows = g.Sum(x => x.WindowsCount),
                    Mac = g.Sum(x => x.MacCount),
                    Android = g.Sum(x => x.AndroidCount),
                    Ios = g.Sum(x => x.IosCount),
                    WindowsMobile = g.Sum(x => x.WindowsMobileCount)
                })
                .OrderByDescending(p => p.Windows + p.Mac + p.Android + p.Ios + p.WindowsMobile)
                .ToList();

        var categories = grouped.Select(p => p.Label).ToList();
        _activationChartOptions.Xaxis = new XAxis { Categories = categories };

        _activationData["Windows"] = grouped.Select(p => new ActivationDataPoint { Product = p.Label, Count = p.Windows }).ToList();
        _activationData["Mac"] = grouped.Select(p => new ActivationDataPoint { Product = p.Label, Count = p.Mac }).ToList();
        _activationData["Android"] = grouped.Select(p => new ActivationDataPoint { Product = p.Label, Count = p.Android }).ToList();
        _activationData["iOS"] = grouped.Select(p => new ActivationDataPoint { Product = p.Label, Count = p.Ios }).ToList();
        _activationData["Windows Mobile"] = grouped.Select(p => new ActivationDataPoint { Product = p.Label, Count = p.WindowsMobile }).ToList();
    }

    public void Dispose()
    {
        TenantFilter.OnChangeAsync -= OnTenantFilterChangedAsync;
    }

    public class AppDataPoint
    {
        public string Label { get; set; } = string.Empty;
        public int Count { get; set; }
    }

    public class AppTableRow
    {
        public string AppName { get; set; } = string.Empty;
        public string TenantName { get; set; } = string.Empty;
        public int UserCount { get; set; }
        public DateTime ReportDate { get; set; }
    }

    public class AppPlatformRow
    {
        public string TenantName { get; set; } = string.Empty;
        public string AppName { get; set; } = string.Empty;
        public int Windows { get; set; }
        public int Mac { get; set; }
        public int Mobile { get; set; }
        public int Web { get; set; }
    }

    public class ActivationDataPoint
    {
        public string Product { get; set; } = string.Empty;
        public int Count { get; set; }
    }
}
