@page "/security"
@using ApexCharts
@using Color = MudBlazor.Color
@using Size = MudBlazor.Size
@inject IMauDataService MauDataService
@inject TenantFilterService TenantFilter
@implements IDisposable

<BrandedPageTitle Page="Security Services" />

<div class="d-flex justify-space-between align-center mb-2">
    <MudText Typo="Typo.h4">Security Services</MudText>
    <ExportMenu Items="@(new[] {
        ("Sign-ins & MFA", "security"),
        ("Defender Alerts", "defender-alerts"),
        ("Suspicious Mail Rules", "mail-rules"),
        ("DLP Policy Matches", "dlp-events"),
        ("External Sharing", "external-sharing") })" />
</div>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Sign-in activity and MFA metrics from Entra audit logs, Microsoft Defender alerts, and external file-sharing activity.
    Requires <PermissionTag Scope="AuditLog.Read.All" />, <PermissionTag Scope="SecurityAlert.Read.All" /> (Defender), and <PermissionTag Scope="ActivityFeed.Read" /> (external sharing, via the Office 365 unified audit log).
</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    <div class="d-flex flex-column align-center justify-center" style="min-height: 400px;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-4">Loading security data...</MudText>
    </div>
}
else
{
@* Tenant Entra ID License Tier Overview *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.Shield" Class="mr-2" />
        Tenant Entra ID License Levels
    </MudText>
    @if (_tenantTiers.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No tenant license data available. Collect data from the Tenants page first.</MudText>
    }
    else
    {
        <MudTable Items="_tenantTiers" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Tenant</MudTh>
                <MudTh>Entra ID Tier</MudTh>
                <MudTh>Sign-in Logs</MudTh>
                <MudTh>MFA Details</MudTh>
                <MudTh>Data Available</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Tenant">@context.TenantName</MudTd>
                <MudTd DataLabel="Tier">
                    <MudChip T="string" Size="Size.Small" Color="@GetTierColor(context.Tier)">
                        @($"Entra ID {context.Tier}")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Sign-in Logs">
                    @if (context.HasSignInAccess)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" />
                    }
                </MudTd>
                <MudTd DataLabel="MFA Details">
                    @if (context.HasMfaDetails)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" />
                    }
                </MudTd>
                <MudTd DataLabel="Data Available">
                    @if (context.HasSignInAccess)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Success">Sign-ins, failures, MFA</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning">No sign-in data (requires P1/P2)</MudText>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
            <strong>Sign-in logs</strong> and <strong>MFA authentication details</strong> require Entra ID P1 or P2 on the target tenant.
            Tenants on the Free tier cannot expose audit log data via Microsoft Graph.
            MFA metrics are derived from the Beta API's <code>AuthenticationDetails</code> — a non-password authentication method must succeed for it to count as MFA.
        </MudAlert>
    }
</MudPaper>

@* MFA / Authentication Method Registration *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Class="mr-2" />
        MFA & Authentication Method Registration
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
        Tenant-wide adoption of strong authentication for member accounts (guests excluded).
        <strong>Entra ID license:</strong> available on <strong>all tiers</strong> (Free, P1, P2) &mdash; uses <PermissionTag Scope="AuditLog.Read.All" />.
    </MudText>
    @if (_mfaTotalUsers == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No MFA registration data available yet. Collect data from the Tenants page first.</MudText>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudProgressCircular Color="@GetRateColor(_mfaRegisteredRate)" Value="@_mfaRegisteredRate" Size="Size.Large" Class="mb-2">
                        <MudText Typo="Typo.body2">@_mfaRegisteredRate.ToString("0")%</MudText>
                    </MudProgressCircular>
                    <MudText Typo="Typo.subtitle2" Align="MudBlazor.Align.Center">MFA Registered</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_mfaRegistered.ToString("N0") of @_mfaTotalUsers.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudProgressCircular Color="@GetRateColor(_mfaCapableRate)" Value="@_mfaCapableRate" Size="Size.Large" Class="mb-2">
                        <MudText Typo="Typo.body2">@_mfaCapableRate.ToString("0")%</MudText>
                    </MudProgressCircular>
                    <MudText Typo="Typo.subtitle2" Align="MudBlazor.Align.Center">MFA Capable</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_mfaCapable.ToString("N0") of @_mfaTotalUsers.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudProgressCircular Color="@GetRateColor(_passwordlessRate)" Value="@_passwordlessRate" Size="Size.Large" Class="mb-2">
                        <MudText Typo="Typo.body2">@_passwordlessRate.ToString("0")%</MudText>
                    </MudProgressCircular>
                    <MudText Typo="Typo.subtitle2" Align="MudBlazor.Align.Center">Passwordless Capable</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_passwordlessCapable.ToString("N0") of @_mfaTotalUsers.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudProgressCircular Color="@GetRateColor(_ssprRate)" Value="@_ssprRate" Size="Size.Large" Class="mb-2">
                        <MudText Typo="Typo.body2">@_ssprRate.ToString("0")%</MudText>
                    </MudProgressCircular>
                    <MudText Typo="Typo.subtitle2" Align="MudBlazor.Align.Center">SSPR Registered</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_ssprRegistered.ToString("N0") of @_mfaTotalUsers.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudPaper>

@* Inactive / Stale Licensed Accounts *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.PersonOff" Class="mr-2" />
        Inactive / Stale Licensed Accounts
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
        Enabled, licensed member accounts with no interactive sign-in (license-waste signal).
        <strong>Entra ID license:</strong> requires <strong>Microsoft Entra ID P1 or P2</strong> (derived from <code>signInActivity</code>); tenants below P1 are skipped during collection. Uses <PermissionTag Scope="AuditLog.Read.All" />.
    </MudText>
    @if (_inactiveTotalLicensed == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No inactive account data available yet. Collect data from the Tenants page first.</MudText>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Licensed Users</MudText>
                    <MudText Typo="Typo.h4">@_inactiveTotalLicensed.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Enabled member accounts</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.subtitle2" Color="Color.Warning">Inactive 30+ days</MudText>
                    <MudText Typo="Typo.h4">@_inactive30.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetPercent(_inactive30).ToString("0")% of licensed</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.subtitle2" Color="Color.Warning">Inactive 90+ days</MudText>
                    <MudText Typo="Typo.h4">@_inactive90.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetPercent(_inactive90).ToString("0")% of licensed</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.subtitle2" Color="Color.Error">Never Signed In</MudText>
                    <MudText Typo="Typo.h4">@_inactiveNever.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetPercent(_inactiveNever).ToString("0")% of licensed</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
        @if (_inactive90 > 0)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3">
                <strong>@_inactive90.ToString("N0")</strong> licensed account(s) have not signed in for 90+ days. Review these for license reclamation to reduce spend.
            </MudAlert>
        }
    }
</MudPaper>

@if (_summaries.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        No security sign-in data available yet. This requires:
        <ul class="mt-2">
            <li>Entra ID P1 or P2 in the target tenant (Free tier does not expose sign-in logs)</li>
            <li><code>AuditLog.Read.All</code> application permission on the app registration</li>
            <li>Background service to have collected at least one cycle of data</li>
        </ul>
    </MudAlert>
}
else
{
    @* KPI Cards *@
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Color="Color.Primary">Total Sign-ins (30d)</MudText>
                <MudText Typo="Typo.h4">@_summaries.Sum(s => s.ActiveUserCount).ToString("N0")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Color="Color.Success">Successful</MudText>
                <MudText Typo="Typo.h4">@_summaries.Sum(s => s.SuccessCount).ToString("N0")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Color="Color.Error">Failed</MudText>
                <MudText Typo="Typo.h4">@_summaries.Sum(s => s.FailureCount).ToString("N0")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Color="Color.Info">MFA Used</MudText>
                <MudText Typo="Typo.h4">@_summaries.Sum(s => s.MfaCount).ToString("N0")</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">via Beta API AuthenticationDetails</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Sign-in Trend Chart *@
    <MudPaper Class="pa-4 mt-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3">Sign-in Activity (30 days)</MudText>
        <ApexChart TItem="DailySignIn" Options="_signInChartOptions" Height="350">
            <ApexPointSeries TItem="DailySignIn"
                             Items="_dailySignIns"
                             Name="Successful"
                             SeriesType="SeriesType.Area"
                             XValue="@(e => e.Date)"
                             YValue="@(e => (decimal?)e.SuccessCount)" />
            <ApexPointSeries TItem="DailySignIn"
                             Items="_dailySignIns"
                             Name="Failed"
                             SeriesType="SeriesType.Area"
                             XValue="@(e => e.Date)"
                             YValue="@(e => (decimal?)e.FailureCount)" />
        </ApexChart>
    </MudPaper>

    @* Per-Service Breakdown *@
    <MudPaper Class="pa-4 mt-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3">Usage by Security Service</MudText>
        <MudGrid>
            @foreach (var service in _byService)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1">
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@service.Key</MudText>
                            <MudGrid>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption">Sign-ins</MudText>
                                    <MudText Typo="Typo.h5">@service.Value.Sum(s => s.ActiveUserCount).ToString("N0")</MudText>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption">Failure Rate</MudText>
                                    <MudText Typo="Typo.h5" Color="@GetFailureColor(service.Value)">
                                        @GetFailureRate(service.Value).ToString("F1")%
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                            <MudProgressLinear Color="@GetFailureColor(service.Value)" 
                                               Value="@GetFailureRate(service.Value)" Class="mt-2" />
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </MudPaper>

    @* MFA Adoption *@
    <MudPaper Class="pa-4 mt-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3">MFA Adoption Rate</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
            MFA is detected via the Graph Beta API's <code>AuthenticationDetails</code> collection.
            A sign-in counts as MFA when a non-password authentication method succeeds (e.g., FIDO2, Authenticator, phone).
            This data is only available from tenants with Entra ID P1/P2.
        </MudText>
        @{
            var totalSignIns = _summaries.Sum(s => s.ActiveUserCount);
            var totalMfa = _summaries.Sum(s => s.MfaCount);
            var mfaRate = totalSignIns > 0 ? (double)totalMfa / totalSignIns * 100 : 0;
        }
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h3" Color="@(mfaRate > 80 ? Color.Success : mfaRate > 50 ? Color.Warning : Color.Error)">
                    @mfaRate.ToString("F1")%
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">of sign-ins used MFA</MudText>
                <MudProgressLinear Color="@(mfaRate > 80 ? Color.Success : mfaRate > 50 ? Color.Warning : Color.Error)"
                                   Value="@mfaRate" Class="mt-3" Style="height: 10px;" />
            </MudItem>
            <MudItem xs="12" md="6">
                @if (mfaRate < 50)
                {
                    <MudAlert Severity="Severity.Error">
                        MFA adoption is critically low. Strongly recommend enforcing Conditional Access policies.
                    </MudAlert>
                }
                else if (mfaRate < 80)
                {
                    <MudAlert Severity="Severity.Warning">
                        MFA adoption could be improved. Consider Conditional Access with MFA requirement for all users.
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Success">
                        Good MFA adoption rate. Continue monitoring for compliance.
                    </MudAlert>
                }
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@* Microsoft Defender Alerts *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.GppMaybe" Class="mr-2" />
        Microsoft Defender Alerts (last 30 days)
    </MudText>
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
        Aggregated from <PermissionTag Scope="SecurityAlert.Read.All" />. Requires a Microsoft Defender / Defender XDR subscription on the tenant.
    </MudText>
    @if (_defenderAlerts.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No Defender alerts available for the selected tenant(s).</MudText>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total Alerts</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_alertTotal.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">High / Critical</MudText>
                    <MudText Typo="Typo.h4" Color="@(_alertHigh > 0 ? Color.Error : Color.Success)">@_alertHigh.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Active</MudText>
                    <MudText Typo="Typo.h4" Color="@(_alertActive > 0 ? Color.Warning : Color.Success)">@_alertActive.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">new or in progress</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Resolved</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Success">@_alertResolved.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12">
                <MudTable Items="_defenderAlerts" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        @if (TenantFilter.IsMultiTenantView) { <MudTh>Tenant</MudTh> }
                        <MudTh>Severity</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh Style="text-align:right">Alerts</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        @if (TenantFilter.IsMultiTenantView) { <MudTd DataLabel="Tenant">@TenantFilter.GetTenantName(context.TenantId)</MudTd> }
                        <MudTd DataLabel="Severity">
                            <MudChip T="string" Size="Size.Small" Color="@GetSeverityColor(context.Severity)" Variant="Variant.Filled">@context.Severity</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Status">@context.Status</MudTd>
                        <MudTd DataLabel="Alerts" Style="text-align:right">@context.AlertCount.ToString("N0")</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>
        </MudGrid>
    }
</MudPaper>

@* External Sharing Activity *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.Share" Class="mr-2" />
        External Sharing Activity (last 30 days)
    </MudText>
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
        SharePoint &amp; OneDrive sharing events from the Office 365 unified audit log (<PermissionTag Scope="ActivityFeed.Read" />). Requires unified audit logging enabled on the tenant.
    </MudText>
    @if (_externalSharing.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No external sharing activity recorded for the selected tenant(s).</MudText>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Anonymous Links</MudText>
                    <MudText Typo="Typo.h4" Color="@(_shareAnonymous > 0 ? Color.Error : Color.Success)">@_shareAnonymous.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">anyone-with-the-link</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">External (Guest)</MudText>
                    <MudText Typo="Typo.h4" Color="@(_shareExternal > 0 ? Color.Warning : Color.Success)">@_shareExternal.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">shared outside org</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Organization</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_shareOrganization.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">people-in-org links</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12">
                <MudTable Items="_externalSharing" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        @if (TenantFilter.IsMultiTenantView) { <MudTh>Tenant</MudTh> }
                        <MudTh>Report Date</MudTh>
                        <MudTh>Share Type</MudTh>
                        <MudTh Style="text-align:right">Events</MudTh>
                        <MudTh Style="text-align:right">Distinct Users</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        @if (TenantFilter.IsMultiTenantView) { <MudTd DataLabel="Tenant">@TenantFilter.GetTenantName(context.TenantId)</MudTd> }
                        <MudTd DataLabel="Report Date">@context.ReportDate.ToString("yyyy-MM-dd")</MudTd>
                        <MudTd DataLabel="Share Type">
                            <MudChip T="string" Size="Size.Small" Color="@GetShareColor(context.ShareType)" Variant="Variant.Filled">@context.ShareType</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Events" Style="text-align:right">@context.EventCount.ToString("N0")</MudTd>
                        <MudTd DataLabel="Distinct Users" Style="text-align:right">@context.DistinctUsers.ToString("N0")</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>
        </MudGrid>
    }
</MudPaper>

@* Suspicious Inbox / Auto-Forwarding Rules (BEC indicator) *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.ForwardToInbox" Class="mr-2" />
        Suspicious Mailbox Rules (last 30 days)
    </MudText>
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
        Inbox-rule and mailbox auto-forwarding changes from the Office 365 unified audit log (<PermissionTag Scope="ActivityFeed.Read" />).
        New forwarding, redirect, or auto-delete rules are a common <strong>business-email-compromise (BEC)</strong> indicator. Requires unified audit logging enabled on the tenant.
    </MudText>
    @if (_mailRules.Count == 0)
    {
        <MudAlert Severity="Severity.Success" Dense="true">No suspicious inbox-rule or auto-forwarding activity recorded for the selected tenant(s).</MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Forwarding</MudText>
                    <MudText Typo="Typo.h4" Color="@(_ruleForwarding > 0 ? Color.Error : Color.Success)">@_ruleForwarding.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">forward-to rules</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Redirect</MudText>
                    <MudText Typo="Typo.h4" Color="@(_ruleRedirect > 0 ? Color.Warning : Color.Success)">@_ruleRedirect.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">redirect-to rules</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Auto-Delete</MudText>
                    <MudText Typo="Typo.h4" Color="@(_ruleDelete > 0 ? Color.Warning : Color.Success)">@_ruleDelete.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">delete-message rules</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12">
                <MudTable Items="_mailRules" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        @if (TenantFilter.IsMultiTenantView) { <MudTh>Tenant</MudTh> }
                        <MudTh>Report Date</MudTh>
                        <MudTh>Rule Type</MudTh>
                        <MudTh Style="text-align:right">Events</MudTh>
                        <MudTh Style="text-align:right">Distinct Mailboxes</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        @if (TenantFilter.IsMultiTenantView) { <MudTd DataLabel="Tenant">@TenantFilter.GetTenantName(context.TenantId)</MudTd> }
                        <MudTd DataLabel="Report Date">@context.ReportDate.ToString("yyyy-MM-dd")</MudTd>
                        <MudTd DataLabel="Rule Type">
                            <MudChip T="string" Size="Size.Small" Color="@GetRuleColor(context.RuleType)" Variant="Variant.Filled">@context.RuleType</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Events" Style="text-align:right">@context.EventCount.ToString("N0")</MudTd>
                        <MudTd DataLabel="Distinct Mailboxes" Style="text-align:right">@context.DistinctMailboxes.ToString("N0")</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>
        </MudGrid>
    }
</MudPaper>

@* DLP Policy Matches (Purview) *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.Policy" Class="mr-2" />
        DLP Policy Matches (last 30 days)
    </MudText>
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
        Microsoft Purview Data Loss Prevention sensitive-data exposure events from the Office 365 unified audit log (<PermissionTag Scope="ActivityFeed.Read" />).
        Only tenants running Purview DLP policies will report matches.
    </MudText>
    @if (_dlpEvents.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Dense="true">
            No DLP policy matches recorded for the selected tenant(s). This usually means <strong>Microsoft Purview DLP is not configured</strong> on the tenant (or no sensitive content was shared in the window).
        </MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total Matches</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_dlpTotal.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">policy hits</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">High Severity</MudText>
                    <MudText Typo="Typo.h4" Color="@(_dlpHigh > 0 ? Color.Error : Color.Success)">@_dlpHigh.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">high-risk matches</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Policies Triggered</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Info">@_dlpPolicyCount.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">distinct policies</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12">
                <MudTable Items="_dlpEvents" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        @if (TenantFilter.IsMultiTenantView) { <MudTh>Tenant</MudTh> }
                        <MudTh>Report Date</MudTh>
                        <MudTh>Policy</MudTh>
                        <MudTh>Severity</MudTh>
                        <MudTh Style="text-align:right">Matches</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        @if (TenantFilter.IsMultiTenantView) { <MudTd DataLabel="Tenant">@TenantFilter.GetTenantName(context.TenantId)</MudTd> }
                        <MudTd DataLabel="Report Date">@context.ReportDate.ToString("yyyy-MM-dd")</MudTd>
                        <MudTd DataLabel="Policy">@context.PolicyName</MudTd>
                        <MudTd DataLabel="Severity">
                            <MudChip T="string" Size="Size.Small" Color="@GetDlpSeverityColor(context.Severity)" Variant="Variant.Filled">@context.Severity</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Matches" Style="text-align:right">@context.MatchCount.ToString("N0")</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>
        </MudGrid>
    }
</MudPaper>
}

@code {
    private List<SecuritySignInSummary> _summaries = [];
    private List<DailySignIn> _dailySignIns = [];
    private Dictionary<string, List<SecuritySignInSummary>> _byService = [];
    private List<TenantEntraTier> _tenantTiers = [];
    private bool _loading = true;

    // MFA registration aggregates (across selected tenants)
    private int _mfaTotalUsers;
    private int _mfaRegistered;
    private int _mfaCapable;
    private int _passwordlessCapable;
    private int _ssprRegistered;
    private double _mfaRegisteredRate;
    private double _mfaCapableRate;
    private double _passwordlessRate;
    private double _ssprRate;

    // Inactive account aggregates (across selected tenants)
    private int _inactiveTotalLicensed;
    private int _inactive30;
    private int _inactive90;
    private int _inactiveNever;

    // Defender alert aggregates
    private List<DefenderAlertSnapshot> _defenderAlerts = [];
    private int _alertTotal, _alertHigh, _alertActive, _alertResolved;

    // External sharing aggregates
    private List<ExternalSharingSnapshot> _externalSharing = [];
    private int _shareAnonymous, _shareExternal, _shareOrganization;

    // Suspicious mail-rule aggregates
    private List<MailRuleEventSnapshot> _mailRules = [];
    private int _ruleForwarding, _ruleRedirect, _ruleDelete;

    // DLP policy-match aggregates
    private List<DlpEventSnapshot> _dlpEvents = [];
    private int _dlpTotal, _dlpHigh, _dlpPolicyCount;

    private ApexChartOptions<DailySignIn> _signInChartOptions = new()
    {
        Yaxis = [new YAxis { Title = new AxisTitle { Text = "Sign-in Count" } }],
        Xaxis = new XAxis { Title = new AxisTitle { Text = "Date" } },
        Legend = new Legend { Show = true, Position = LegendPosition.Bottom },
        Chart = new Chart { ForeColor = "var(--mud-palette-text-primary)" }
    };

    protected override async Task OnInitializedAsync()
    {
        TenantFilter.OnChangeAsync += OnTenantFilterChangedAsync;
        await LoadData();
    }

    private Task OnTenantFilterChangedAsync()
    {
        return InvokeAsync(async () =>
        {
            TenantFilter.SetLoading(true);
            _loading = true;
            StateHasChanged();
            await LoadData();
            TenantFilter.SetLoading(false);
            StateHasChanged();
        });
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();

        var tenantIds = TenantFilter.GetFilteredTenantIds();
        var allTiers = await MauDataService.GetTenantEntraIdTiersAsync();
        if (tenantIds != null)
        {
            var ids = tenantIds.ToHashSet();
            _tenantTiers = allTiers.Where(t => ids.Contains(t.TenantId)).ToList();
        }
        else
        {
            _tenantTiers = allTiers;
        }
        _summaries = await MauDataService.GetSecuritySummaryAsync(tenantIds, days: 30);

        // MFA registration aggregates (latest snapshot per tenant, summed)
        var mfaSnapshots = await MauDataService.GetMfaRegistrationAsync(tenantIds);
        _mfaTotalUsers = mfaSnapshots.Sum(m => m.TotalUsers);
        _mfaRegistered = mfaSnapshots.Sum(m => m.MfaRegistered);
        _mfaCapable = mfaSnapshots.Sum(m => m.MfaCapable);
        _passwordlessCapable = mfaSnapshots.Sum(m => m.PasswordlessCapable);
        _ssprRegistered = mfaSnapshots.Sum(m => m.SsprRegistered);
        _mfaRegisteredRate = _mfaTotalUsers > 0 ? (double)_mfaRegistered / _mfaTotalUsers * 100 : 0;
        _mfaCapableRate = _mfaTotalUsers > 0 ? (double)_mfaCapable / _mfaTotalUsers * 100 : 0;
        _passwordlessRate = _mfaTotalUsers > 0 ? (double)_passwordlessCapable / _mfaTotalUsers * 100 : 0;
        _ssprRate = _mfaTotalUsers > 0 ? (double)_ssprRegistered / _mfaTotalUsers * 100 : 0;

        // Inactive account aggregates (latest snapshot per tenant, summed)
        var inactiveSnapshots = await MauDataService.GetInactiveAccountsAsync(tenantIds);
        _inactiveTotalLicensed = inactiveSnapshots.Sum(s => s.TotalLicensedUsers);
        _inactive30 = inactiveSnapshots.Sum(s => s.Inactive30);
        _inactive90 = inactiveSnapshots.Sum(s => s.Inactive90);
        _inactiveNever = inactiveSnapshots.Sum(s => s.NeverSignedIn);

        // Defender alert aggregates (latest snapshot per tenant)
        _defenderAlerts = (await MauDataService.GetDefenderAlertsAsync(tenantIds))
            .OrderBy(a => SeverityRank(a.Severity)).ThenBy(a => a.Status).ToList();
        _alertTotal = _defenderAlerts.Sum(a => a.AlertCount);
        _alertHigh = _defenderAlerts.Where(a => a.Severity is "High" or "Critical").Sum(a => a.AlertCount);
        _alertActive = _defenderAlerts.Where(a => a.Status is "new" or "inProgress" or "New" or "InProgress").Sum(a => a.AlertCount);
        _alertResolved = _defenderAlerts.Where(a => a.Status is "resolved" or "Resolved").Sum(a => a.AlertCount);

        // External sharing aggregates (last 30 days)
        _externalSharing = (await MauDataService.GetExternalSharingAsync(tenantIds, days: 30))
            .OrderByDescending(s => s.ReportDate).ThenBy(s => s.ShareType).ToList();
        _shareAnonymous = _externalSharing.Where(s => s.ShareType == "Anonymous").Sum(s => s.EventCount);
        _shareExternal = _externalSharing.Where(s => s.ShareType == "External").Sum(s => s.EventCount);
        _shareOrganization = _externalSharing.Where(s => s.ShareType == "Organization").Sum(s => s.EventCount);

        // Suspicious mail-rule aggregates (last 30 days)
        _mailRules = (await MauDataService.GetMailRuleEventsAsync(tenantIds, days: 30))
            .OrderByDescending(s => s.ReportDate).ThenBy(s => s.RuleType).ToList();
        _ruleForwarding = _mailRules.Where(s => s.RuleType == "Forwarding").Sum(s => s.EventCount);
        _ruleRedirect = _mailRules.Where(s => s.RuleType == "Redirect").Sum(s => s.EventCount);
        _ruleDelete = _mailRules.Where(s => s.RuleType == "Delete").Sum(s => s.EventCount);

        // DLP policy-match aggregates (last 30 days)
        _dlpEvents = (await MauDataService.GetDlpEventsAsync(tenantIds, days: 30))
            .OrderByDescending(s => s.ReportDate).ThenByDescending(s => s.MatchCount).ToList();
        _dlpTotal = _dlpEvents.Sum(s => s.MatchCount);
        _dlpHigh = _dlpEvents.Where(s => string.Equals(s.Severity, "High", StringComparison.OrdinalIgnoreCase)).Sum(s => s.MatchCount);
        _dlpPolicyCount = _dlpEvents.Select(s => s.PolicyName).Distinct(StringComparer.OrdinalIgnoreCase).Count();

        _dailySignIns = _summaries
            .GroupBy(s => s.ReportDate.ToString("MM-dd"))
            .Select(g => new DailySignIn
            {
                Date = g.Key,
                SuccessCount = g.Sum(s => s.SuccessCount),
                FailureCount = g.Sum(s => s.FailureCount)
            })
            .OrderBy(d => d.Date)
            .ToList();

        // When multi-tenant, group by "Service (Tenant)" for clarity
        if (TenantFilter.IsMultiTenantView)
        {
            _byService = _summaries
                .GroupBy(s => $"{s.ServiceName} ({TenantFilter.GetTenantName(s.TenantId)})")
                .ToDictionary(g => g.Key, g => g.ToList());
        }
        else
        {
            _byService = _summaries
                .GroupBy(s => s.ServiceName)
                .ToDictionary(g => g.Key, g => g.ToList());
        }

        _loading = false;
    }

    private Color GetTierColor(string tier)
    {
        return tier switch
        {
            "P2" => Color.Success,
            "P1" => Color.Info,
            _ => Color.Warning
        };
    }

    private static int SeverityRank(string severity) => severity switch
    {
        "Critical" => 0,
        "High" => 1,
        "Medium" => 2,
        "Low" => 3,
        _ => 4
    };

    private static Color GetSeverityColor(string severity) => severity switch
    {
        "Critical" or "High" => Color.Error,
        "Medium" => Color.Warning,
        "Low" => Color.Info,
        _ => Color.Default
    };

    private static Color GetShareColor(string shareType) => shareType switch
    {
        "Anonymous" => Color.Error,
        "External" => Color.Warning,
        _ => Color.Info
    };

    private static Color GetRuleColor(string ruleType) => ruleType switch
    {
        "Forwarding" => Color.Error,
        "Redirect" => Color.Warning,
        "Delete" => Color.Warning,
        _ => Color.Info
    };

    private static Color GetDlpSeverityColor(string severity) => severity?.ToLowerInvariant() switch
    {
        "high" => Color.Error,
        "medium" => Color.Warning,
        "low" => Color.Info,
        _ => Color.Default
    };

    private Color GetRateColor(double rate)
    {
        return rate switch
        {
            >= 80 => Color.Success,
            >= 50 => Color.Warning,
            _ => Color.Error
        };
    }

    private double GetPercent(int count)
    {
        return _inactiveTotalLicensed > 0 ? (double)count / _inactiveTotalLicensed * 100 : 0;
    }

    private double GetFailureRate(List<SecuritySignInSummary> items)
    {
        var total = items.Sum(s => s.ActiveUserCount);
        if (total == 0) return 0;
        return (double)items.Sum(s => s.FailureCount) / total * 100;
    }

    private Color GetFailureColor(List<SecuritySignInSummary> items)
    {
        var rate = GetFailureRate(items);
        return rate switch
        {
            > 20 => Color.Error,
            > 10 => Color.Warning,
            _ => Color.Success
        };
    }

    public class DailySignIn
    {
        public string Date { get; set; } = string.Empty;
        public int SuccessCount { get; set; }
        public int FailureCount { get; set; }
    }

    public void Dispose()
    {
        TenantFilter.OnChangeAsync -= OnTenantFilterChangedAsync;
    }
}
