@page "/security"
@using ApexCharts
@using Color = MudBlazor.Color
@using Size = MudBlazor.Size
@inject IMauDataService MauDataService
@inject TenantFilterService TenantFilter
@implements IDisposable

<PageTitle>Security Services</PageTitle>

<div class="d-flex justify-space-between align-center mb-2">
    <MudText Typo="Typo.h4">Security Services</MudText>
    <ExportButton Feature="security" />
</div>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Sign-in activity and MFA metrics from Entra audit logs. Requires <PermissionTag Scope="AuditLog.Read.All" />.
</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    <div class="d-flex flex-column align-center justify-center" style="min-height: 400px;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-4">Loading security data...</MudText>
    </div>
}
else
{
@* Tenant Entra ID License Tier Overview *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.Shield" Class="mr-2" />
        Tenant Entra ID License Levels
    </MudText>
    @if (_tenantTiers.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No tenant license data available. Collect data from the Tenants page first.</MudText>
    }
    else
    {
        <MudTable Items="_tenantTiers" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Tenant</MudTh>
                <MudTh>Entra ID Tier</MudTh>
                <MudTh>Sign-in Logs</MudTh>
                <MudTh>MFA Details</MudTh>
                <MudTh>Data Available</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Tenant">@context.TenantName</MudTd>
                <MudTd DataLabel="Tier">
                    <MudChip T="string" Size="Size.Small" Color="@GetTierColor(context.Tier)">
                        @($"Entra ID {context.Tier}")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Sign-in Logs">
                    @if (context.HasSignInAccess)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" />
                    }
                </MudTd>
                <MudTd DataLabel="MFA Details">
                    @if (context.HasMfaDetails)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" />
                    }
                </MudTd>
                <MudTd DataLabel="Data Available">
                    @if (context.HasSignInAccess)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Success">Sign-ins, failures, MFA</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning">No sign-in data (requires P1/P2)</MudText>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
            <strong>Sign-in logs</strong> and <strong>MFA authentication details</strong> require Entra ID P1 or P2 on the target tenant.
            Tenants on the Free tier cannot expose audit log data via Microsoft Graph.
            MFA metrics are derived from the Beta API's <code>AuthenticationDetails</code> — a non-password authentication method must succeed for it to count as MFA.
        </MudAlert>
    }
</MudPaper>

@* MFA / Authentication Method Registration *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Class="mr-2" />
        MFA & Authentication Method Registration
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
        Tenant-wide adoption of strong authentication for member accounts (guests excluded).
        <strong>Entra ID license:</strong> available on <strong>all tiers</strong> (Free, P1, P2) &mdash; uses <PermissionTag Scope="AuditLog.Read.All" />.
    </MudText>
    @if (_mfaTotalUsers == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No MFA registration data available yet. Collect data from the Tenants page first.</MudText>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudProgressCircular Color="@GetRateColor(_mfaRegisteredRate)" Value="@_mfaRegisteredRate" Size="Size.Large" Class="mb-2">
                        <MudText Typo="Typo.body2">@_mfaRegisteredRate.ToString("0")%</MudText>
                    </MudProgressCircular>
                    <MudText Typo="Typo.subtitle2" Align="MudBlazor.Align.Center">MFA Registered</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_mfaRegistered.ToString("N0") of @_mfaTotalUsers.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudProgressCircular Color="@GetRateColor(_mfaCapableRate)" Value="@_mfaCapableRate" Size="Size.Large" Class="mb-2">
                        <MudText Typo="Typo.body2">@_mfaCapableRate.ToString("0")%</MudText>
                    </MudProgressCircular>
                    <MudText Typo="Typo.subtitle2" Align="MudBlazor.Align.Center">MFA Capable</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_mfaCapable.ToString("N0") of @_mfaTotalUsers.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudProgressCircular Color="@GetRateColor(_passwordlessRate)" Value="@_passwordlessRate" Size="Size.Large" Class="mb-2">
                        <MudText Typo="Typo.body2">@_passwordlessRate.ToString("0")%</MudText>
                    </MudProgressCircular>
                    <MudText Typo="Typo.subtitle2" Align="MudBlazor.Align.Center">Passwordless Capable</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_passwordlessCapable.ToString("N0") of @_mfaTotalUsers.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0" Outlined="true">
                    <MudProgressCircular Color="@GetRateColor(_ssprRate)" Value="@_ssprRate" Size="Size.Large" Class="mb-2">
                        <MudText Typo="Typo.body2">@_ssprRate.ToString("0")%</MudText>
                    </MudProgressCircular>
                    <MudText Typo="Typo.subtitle2" Align="MudBlazor.Align.Center">SSPR Registered</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_ssprRegistered.ToString("N0") of @_mfaTotalUsers.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudPaper>

@* Inactive / Stale Licensed Accounts *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.PersonOff" Class="mr-2" />
        Inactive / Stale Licensed Accounts
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
        Enabled, licensed member accounts with no interactive sign-in (license-waste signal).
        <strong>Entra ID license:</strong> requires <strong>Microsoft Entra ID P1 or P2</strong> (derived from <code>signInActivity</code>); tenants below P1 are skipped during collection. Uses <PermissionTag Scope="AuditLog.Read.All" />.
    </MudText>
    @if (_inactiveTotalLicensed == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No inactive account data available yet. Collect data from the Tenants page first.</MudText>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Licensed Users</MudText>
                    <MudText Typo="Typo.h4">@_inactiveTotalLicensed.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Enabled member accounts</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.subtitle2" Color="Color.Warning">Inactive 30+ days</MudText>
                    <MudText Typo="Typo.h4">@_inactive30.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetPercent(_inactive30).ToString("0")% of licensed</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.subtitle2" Color="Color.Warning">Inactive 90+ days</MudText>
                    <MudText Typo="Typo.h4">@_inactive90.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetPercent(_inactive90).ToString("0")% of licensed</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.subtitle2" Color="Color.Error">Never Signed In</MudText>
                    <MudText Typo="Typo.h4">@_inactiveNever.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetPercent(_inactiveNever).ToString("0")% of licensed</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
        @if (_inactive90 > 0)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3">
                <strong>@_inactive90.ToString("N0")</strong> licensed account(s) have not signed in for 90+ days. Review these for license reclamation to reduce spend.
            </MudAlert>
        }
    }
</MudPaper>

@if (_summaries.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        No security sign-in data available yet. This requires:
        <ul class="mt-2">
            <li>Entra ID P1 or P2 in the target tenant (Free tier does not expose sign-in logs)</li>
            <li><code>AuditLog.Read.All</code> application permission on the app registration</li>
            <li>Background service to have collected at least one cycle of data</li>
        </ul>
    </MudAlert>
}
else
{
    @* KPI Cards *@
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Color="Color.Primary">Total Sign-ins (30d)</MudText>
                <MudText Typo="Typo.h4">@_summaries.Sum(s => s.ActiveUserCount).ToString("N0")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Color="Color.Success">Successful</MudText>
                <MudText Typo="Typo.h4">@_summaries.Sum(s => s.SuccessCount).ToString("N0")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Color="Color.Error">Failed</MudText>
                <MudText Typo="Typo.h4">@_summaries.Sum(s => s.FailureCount).ToString("N0")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Color="Color.Info">MFA Used</MudText>
                <MudText Typo="Typo.h4">@_summaries.Sum(s => s.MfaCount).ToString("N0")</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">via Beta API AuthenticationDetails</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Sign-in Trend Chart *@
    <MudPaper Class="pa-4 mt-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3">Sign-in Activity (30 days)</MudText>
        <ApexChart TItem="DailySignIn" Options="_signInChartOptions" Height="350">
            <ApexPointSeries TItem="DailySignIn"
                             Items="_dailySignIns"
                             Name="Successful"
                             SeriesType="SeriesType.Area"
                             XValue="@(e => e.Date)"
                             YValue="@(e => (decimal?)e.SuccessCount)" />
            <ApexPointSeries TItem="DailySignIn"
                             Items="_dailySignIns"
                             Name="Failed"
                             SeriesType="SeriesType.Area"
                             XValue="@(e => e.Date)"
                             YValue="@(e => (decimal?)e.FailureCount)" />
        </ApexChart>
    </MudPaper>

    @* Per-Service Breakdown *@
    <MudPaper Class="pa-4 mt-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3">Usage by Security Service</MudText>
        <MudGrid>
            @foreach (var service in _byService)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1">
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@service.Key</MudText>
                            <MudGrid>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption">Sign-ins</MudText>
                                    <MudText Typo="Typo.h5">@service.Value.Sum(s => s.ActiveUserCount).ToString("N0")</MudText>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption">Failure Rate</MudText>
                                    <MudText Typo="Typo.h5" Color="@GetFailureColor(service.Value)">
                                        @GetFailureRate(service.Value).ToString("F1")%
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                            <MudProgressLinear Color="@GetFailureColor(service.Value)" 
                                               Value="@GetFailureRate(service.Value)" Class="mt-2" />
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </MudPaper>

    @* MFA Adoption *@
    <MudPaper Class="pa-4 mt-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3">MFA Adoption Rate</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
            MFA is detected via the Graph Beta API's <code>AuthenticationDetails</code> collection.
            A sign-in counts as MFA when a non-password authentication method succeeds (e.g., FIDO2, Authenticator, phone).
            This data is only available from tenants with Entra ID P1/P2.
        </MudText>
        @{
            var totalSignIns = _summaries.Sum(s => s.ActiveUserCount);
            var totalMfa = _summaries.Sum(s => s.MfaCount);
            var mfaRate = totalSignIns > 0 ? (double)totalMfa / totalSignIns * 100 : 0;
        }
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h3" Color="@(mfaRate > 80 ? Color.Success : mfaRate > 50 ? Color.Warning : Color.Error)">
                    @mfaRate.ToString("F1")%
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">of sign-ins used MFA</MudText>
                <MudProgressLinear Color="@(mfaRate > 80 ? Color.Success : mfaRate > 50 ? Color.Warning : Color.Error)"
                                   Value="@mfaRate" Class="mt-3" Style="height: 10px;" />
            </MudItem>
            <MudItem xs="12" md="6">
                @if (mfaRate < 50)
                {
                    <MudAlert Severity="Severity.Error">
                        MFA adoption is critically low. Strongly recommend enforcing Conditional Access policies.
                    </MudAlert>
                }
                else if (mfaRate < 80)
                {
                    <MudAlert Severity="Severity.Warning">
                        MFA adoption could be improved. Consider Conditional Access with MFA requirement for all users.
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Success">
                        Good MFA adoption rate. Continue monitoring for compliance.
                    </MudAlert>
                }
            </MudItem>
        </MudGrid>
    </MudPaper>
}
}

@code {
    private List<SecuritySignInSummary> _summaries = [];
    private List<DailySignIn> _dailySignIns = [];
    private Dictionary<string, List<SecuritySignInSummary>> _byService = [];
    private List<TenantEntraTier> _tenantTiers = [];
    private bool _loading = true;

    // MFA registration aggregates (across selected tenants)
    private int _mfaTotalUsers;
    private int _mfaRegistered;
    private int _mfaCapable;
    private int _passwordlessCapable;
    private int _ssprRegistered;
    private double _mfaRegisteredRate;
    private double _mfaCapableRate;
    private double _passwordlessRate;
    private double _ssprRate;

    // Inactive account aggregates (across selected tenants)
    private int _inactiveTotalLicensed;
    private int _inactive30;
    private int _inactive90;
    private int _inactiveNever;

    private ApexChartOptions<DailySignIn> _signInChartOptions = new()
    {
        Yaxis = [new YAxis { Title = new AxisTitle { Text = "Sign-in Count" } }],
        Xaxis = new XAxis { Title = new AxisTitle { Text = "Date" } },
        Legend = new Legend { Show = true, Position = LegendPosition.Bottom },
        Chart = new Chart { ForeColor = "var(--mud-palette-text-primary)" }
    };

    protected override async Task OnInitializedAsync()
    {
        TenantFilter.OnChangeAsync += OnTenantFilterChangedAsync;
        await LoadData();
    }

    private Task OnTenantFilterChangedAsync()
    {
        return InvokeAsync(async () =>
        {
            TenantFilter.SetLoading(true);
            _loading = true;
            StateHasChanged();
            await LoadData();
            TenantFilter.SetLoading(false);
            StateHasChanged();
        });
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();

        var tenantIds = TenantFilter.GetFilteredTenantIds();
        var allTiers = await MauDataService.GetTenantEntraIdTiersAsync();
        if (tenantIds != null)
        {
            var ids = tenantIds.ToHashSet();
            _tenantTiers = allTiers.Where(t => ids.Contains(t.TenantId)).ToList();
        }
        else
        {
            _tenantTiers = allTiers;
        }
        _summaries = await MauDataService.GetSecuritySummaryAsync(tenantIds, days: 30);

        // MFA registration aggregates (latest snapshot per tenant, summed)
        var mfaSnapshots = await MauDataService.GetMfaRegistrationAsync(tenantIds);
        _mfaTotalUsers = mfaSnapshots.Sum(m => m.TotalUsers);
        _mfaRegistered = mfaSnapshots.Sum(m => m.MfaRegistered);
        _mfaCapable = mfaSnapshots.Sum(m => m.MfaCapable);
        _passwordlessCapable = mfaSnapshots.Sum(m => m.PasswordlessCapable);
        _ssprRegistered = mfaSnapshots.Sum(m => m.SsprRegistered);
        _mfaRegisteredRate = _mfaTotalUsers > 0 ? (double)_mfaRegistered / _mfaTotalUsers * 100 : 0;
        _mfaCapableRate = _mfaTotalUsers > 0 ? (double)_mfaCapable / _mfaTotalUsers * 100 : 0;
        _passwordlessRate = _mfaTotalUsers > 0 ? (double)_passwordlessCapable / _mfaTotalUsers * 100 : 0;
        _ssprRate = _mfaTotalUsers > 0 ? (double)_ssprRegistered / _mfaTotalUsers * 100 : 0;

        // Inactive account aggregates (latest snapshot per tenant, summed)
        var inactiveSnapshots = await MauDataService.GetInactiveAccountsAsync(tenantIds);
        _inactiveTotalLicensed = inactiveSnapshots.Sum(s => s.TotalLicensedUsers);
        _inactive30 = inactiveSnapshots.Sum(s => s.Inactive30);
        _inactive90 = inactiveSnapshots.Sum(s => s.Inactive90);
        _inactiveNever = inactiveSnapshots.Sum(s => s.NeverSignedIn);

        _dailySignIns = _summaries
            .GroupBy(s => s.ReportDate.ToString("MM-dd"))
            .Select(g => new DailySignIn
            {
                Date = g.Key,
                SuccessCount = g.Sum(s => s.SuccessCount),
                FailureCount = g.Sum(s => s.FailureCount)
            })
            .OrderBy(d => d.Date)
            .ToList();

        // When multi-tenant, group by "Service (Tenant)" for clarity
        if (TenantFilter.IsMultiTenantView)
        {
            _byService = _summaries
                .GroupBy(s => $"{s.ServiceName} ({TenantFilter.GetTenantName(s.TenantId)})")
                .ToDictionary(g => g.Key, g => g.ToList());
        }
        else
        {
            _byService = _summaries
                .GroupBy(s => s.ServiceName)
                .ToDictionary(g => g.Key, g => g.ToList());
        }

        _loading = false;
    }

    private Color GetTierColor(string tier)
    {
        return tier switch
        {
            "P2" => Color.Success,
            "P1" => Color.Info,
            _ => Color.Warning
        };
    }

    private Color GetRateColor(double rate)
    {
        return rate switch
        {
            >= 80 => Color.Success,
            >= 50 => Color.Warning,
            _ => Color.Error
        };
    }

    private double GetPercent(int count)
    {
        return _inactiveTotalLicensed > 0 ? (double)count / _inactiveTotalLicensed * 100 : 0;
    }

    private double GetFailureRate(List<SecuritySignInSummary> items)
    {
        var total = items.Sum(s => s.ActiveUserCount);
        if (total == 0) return 0;
        return (double)items.Sum(s => s.FailureCount) / total * 100;
    }

    private Color GetFailureColor(List<SecuritySignInSummary> items)
    {
        var rate = GetFailureRate(items);
        return rate switch
        {
            > 20 => Color.Error,
            > 10 => Color.Warning,
            _ => Color.Success
        };
    }

    public class DailySignIn
    {
        public string Date { get; set; } = string.Empty;
        public int SuccessCount { get; set; }
        public int FailureCount { get; set; }
    }

    public void Dispose()
    {
        TenantFilter.OnChangeAsync -= OnTenantFilterChangedAsync;
    }
}
