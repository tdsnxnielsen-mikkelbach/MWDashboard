@page "/tenants"
@using MWDashboard.Models
@using MWDashboard.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<MauDbContext> DbFactory
@inject IConfiguration Configuration
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Tenant Management</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Tenant Management</MudText>

<MudGrid>
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Register New Tenant</MudText>
            <MudTextField @bind-Value="_newTenant.TenantId" Label="Tenant ID (GUID)" Required="true" Class="mb-3" />
            <MudTextField @bind-Value="_newTenant.TenantName" Label="Tenant Name" Required="true" Class="mb-3" />
            <MudTextField @bind-Value="_newTenant.DisplayName" Label="Display Name" Class="mb-3" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddTenant" Disabled="@(!IsValid)">
                Add Tenant
            </MudButton>
            @if (!string.IsNullOrEmpty(_message))
            {
                <MudAlert Severity="@_severity" Class="mt-3">@_message</MudAlert>
            }
        </MudPaper>

        <MudPaper Class="pa-4 mt-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Admin Consent Link Generator</MudText>
            <MudText Typo="Typo.body2" Class="mb-3">
                Generate a consent URL for a tenant admin to authorize this application.
                Send this link to the customer's Global Admin.
            </MudText>
            <MudTextField @bind-Value="_consentTenantId" Label="Target Tenant ID (GUID)" Class="mb-3" />
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="GenerateConsentUrl" 
                       Disabled="@string.IsNullOrWhiteSpace(_consentTenantId)">
                Generate URL
            </MudButton>
            @if (!string.IsNullOrEmpty(_consentUrl))
            {
                <MudAlert Severity="Severity.Info" Class="mt-3">
                    <MudText Typo="Typo.body2" Class="mb-1">Send this URL to the tenant admin:</MudText>
                    <MudLink Href="@_consentUrl" Target="_blank" Typo="Typo.caption" Style="word-break: break-all;">
                        @_consentUrl
                    </MudLink>
                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" 
                               OnClick="CopyConsentUrl" Class="mt-2">
                        Copy to clipboard
                    </MudButton>
                </MudAlert>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Registered Tenants</MudText>
            <MudTable Items="_tenants" Dense="true" Hover="true" Loading="_loading">
                <HeaderContent>
                    <MudTh>Tenant Name</MudTh>
                    <MudTh>Tenant ID</MudTh>
                    <MudTh>Active</MudTh>
                    <MudTh>Onboarded</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">@context.DisplayName</MudTd>
                    <MudTd DataLabel="Tenant ID"><MudText Typo="Typo.caption">@context.TenantId</MudText></MudTd>
                    <MudTd DataLabel="Active">
                        <MudSwitch T="bool" Value="context.IsActive" ValueChanged="@(v => ToggleActive(context))" Color="Color.Success" />
                    </MudTd>
                    <MudTd DataLabel="Onboarded">@context.OnboardedAt.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd>
                        <MudTooltip Text="Open admin consent URL">
                            <MudIconButton Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Info" Size="Size.Small" 
                                           Href="@GetConsentUrlForTenant(context.TenantId)" Target="_blank" />
                        </MudTooltip>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteTenant(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private List<TenantInfo> _tenants = [];
    private TenantInfo _newTenant = new();
    private bool _loading = true;
    private string _message = string.Empty;
    private Severity _severity = Severity.Info;
    private string _consentTenantId = string.Empty;
    private string _consentUrl = string.Empty;

    private string ClientId => Configuration["AzureAd:ClientId"] ?? string.Empty;

    private bool IsValid => !string.IsNullOrWhiteSpace(_newTenant.TenantId) && !string.IsNullOrWhiteSpace(_newTenant.TenantName);

    protected override async Task OnInitializedAsync()
    {
        await LoadTenants();
    }

    private async Task LoadTenants()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        _tenants = await db.Tenants.OrderBy(t => t.TenantName).ToListAsync();
        _loading = false;
    }

    private async Task AddTenant()
    {
        if (!IsValid) return;

        await using var db = await DbFactory.CreateDbContextAsync();

        var exists = await db.Tenants.AnyAsync(t => t.TenantId == _newTenant.TenantId);
        if (exists)
        {
            _message = "Tenant with this ID already exists.";
            _severity = Severity.Warning;
            return;
        }

        if (string.IsNullOrWhiteSpace(_newTenant.DisplayName))
            _newTenant.DisplayName = _newTenant.TenantName;

        _newTenant.OnboardedAt = DateTime.UtcNow;
        _newTenant.IsActive = true;

        db.Tenants.Add(_newTenant);
        await db.SaveChangesAsync();

        _message = $"Tenant '{_newTenant.TenantName}' registered successfully.";
        _severity = Severity.Success;
        _newTenant = new TenantInfo();

        await LoadTenants();
    }

    private async Task ToggleActive(TenantInfo tenant)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Tenants.FindAsync(tenant.Id);
        if (entity != null)
        {
            entity.IsActive = !entity.IsActive;
            await db.SaveChangesAsync();
        }
        await LoadTenants();
    }

    private async Task DeleteTenant(TenantInfo tenant)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Tenants.FindAsync(tenant.Id);
        if (entity != null)
        {
            db.Tenants.Remove(entity);
            await db.SaveChangesAsync();
        }
        await LoadTenants();
    }

    private string GetConsentUrlForTenant(string tenantId)
    {
        return $"https://login.microsoftonline.com/{Uri.EscapeDataString(tenantId)}/adminconsent" +
               $"?client_id={Uri.EscapeDataString(ClientId)}" +
               $"&redirect_uri={Uri.EscapeDataString("https://localhost")}" +
               $"&scope=https://graph.microsoft.com/.default";
    }

    private void GenerateConsentUrl()
    {
        if (string.IsNullOrWhiteSpace(_consentTenantId)) return;
        _consentUrl = GetConsentUrlForTenant(_consentTenantId.Trim());
    }

    private async Task CopyConsentUrl()
    {
        // JS interop for clipboard copy
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _consentUrl);
    }
}
